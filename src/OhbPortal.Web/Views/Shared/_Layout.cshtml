@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    bool istEditor = User.IsInRole("Editor") || User.IsInRole("Admin") || User.IsInRole("Bereichsverantwortlicher");
    bool istApprover = User.IsInRole("Approver") || User.IsInRole("Admin");
    bool istAdmin = User.IsInRole("Admin");
}
<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Organisationshandbuch</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/merkur.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('mc-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>
<body class="mc-body">

@if (User.Identity?.IsAuthenticated == true)
{
    <aside class="mc-sidebar" id="mcSidebar">
        <div class="mc-sidebar-brand">
            <a asp-controller="Dashboard" asp-action="Index" class="mc-logo" style="text-decoration:none">
                <img src="~/images/merkur-logo.svg" alt="Merkur Privatbank" class="mc-logo-img" />
                <div class="mc-logo-title">Organisations­handbuch</div>
                <div class="mc-logo-subtitle">MERKUR PRIVATBANK KGaA</div>
            </a>
        </div>

        <div class="mc-sidebar-bank">
            <div class="mc-sidebar-bank-label">Angemeldet als</div>
            <div class="mc-sidebar-bank-name">@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</div>
            <div class="mc-sidebar-bank-user">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "–")</div>
        </div>

        <ul class="mc-nav">
            <li class="mc-nav-item">
                <a asp-controller="Dashboard" asp-action="Index"
                   class="mc-nav-link @(ctrl == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Kapitel" asp-action="Index"
                   class="mc-nav-link @(ctrl == "Kapitel" ? "active" : "")">
                    <i class="bi bi-diagram-3"></i> <span>Themenbaum</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Dokumente" asp-action="Index"
                   class="mc-nav-link @(ctrl == "Dokumente" && action == "Index" ? "active" : "")">
                    <i class="bi bi-file-earmark-text"></i> <span>Dokumente</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Freigaben" asp-action="Meine"
                   class="mc-nav-link @(ctrl == "Freigaben" ? "active" : "")">
                    <i class="bi bi-check2-square"></i> <span>Meine Freigaben</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Kenntnisnahmen" asp-action="Meine"
                   class="mc-nav-link @(ctrl == "Kenntnisnahmen" ? "active" : "")">
                    <i class="bi bi-eye"></i> <span>Meine Kenntnisnahmen</span>
                </a>
            </li>
            @if (istAdmin)
            {
                <li class="mc-nav-item" style="margin-top:.5rem; border-top:1px solid var(--mc-border); padding-top:.5rem;">
                    <a asp-controller="Admin" asp-action="Index"
                       class="mc-nav-link @(ctrl == "Admin" ? "active" : "")">
                        <i class="bi bi-shield-lock"></i> <span>Administration</span>
                    </a>
                </li>
            }
            <li class="mc-nav-item" style="@(istAdmin ? "" : "margin-top:.5rem; border-top:1px solid var(--mc-border); padding-top:.5rem;")">
                <a asp-controller="Dokumente" asp-action="Archiv"
                   class="mc-nav-link @(ctrl == "Dokumente" && action == "Archiv" ? "active" : "")">
                    <i class="bi bi-archive"></i> <span>Archiv</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Dokumente" asp-action="Papierkorb"
                   class="mc-nav-link @(ctrl == "Dokumente" && action == "Papierkorb" ? "active" : "")">
                    <i class="bi bi-trash"></i> <span>Papierkorb</span>
                </a>
            </li>
        </ul>

        <!-- Abmelden-Button auskommentiert (Auto-Login aktiv)
        <div class="mc-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="mc-logout-btn">
                    <i class="bi bi-box-arrow-right"></i> Abmelden
                </button>
            </form>
        </div>
        -->
    </aside>

    <div class="mc-main">
        <header class="mc-topbar" style="gap:.75rem;">
            <button class="mc-sidebar-toggle d-lg-none" id="sidebarToggle" aria-label="Men&uuml; &ouml;ffnen">
                <i class="bi bi-list"></i>
            </button>

            <form action="/Search" method="get" id="topbarSearchForm"
                  style="flex:1; display:flex; align-items:center; gap:0;" autocomplete="off">
                <input type="hidden" name="mode" id="topbarMode" value="smart" />
                <button type="button" class="topbar-pick-btn topbar-pick-smart"
                        onclick="topbarSetMode('smart')" title="Suche ohne KI"
                        style="border-radius:var(--mc-radius-sm,8px) 0 0 var(--mc-radius-sm,8px); border:1.5px solid var(--mc-border,#ddd); border-right:none; height:42px; padding:0 .8rem; display:flex; align-items:center; gap:.35rem; background:var(--mc-bg-card,#fff); color:var(--mc-text-muted,#999); font-size:.82rem; font-weight:600; cursor:pointer; white-space:nowrap; transition:all .2s;">
                    <i class="bi bi-cpu"></i><span class="d-none d-md-inline">Suche ohne KI</span>
                </button>
                <button type="button" class="topbar-pick-btn topbar-pick-ai"
                        onclick="topbarSetMode('ai')" title="KI-Suche"
                        style="border:1.5px solid var(--mc-border,#ddd); border-right:none; height:42px; padding:0 .8rem; display:flex; align-items:center; gap:.35rem; background:var(--mc-bg-card,#fff); color:var(--mc-text-muted,#999); font-size:.82rem; font-weight:600; cursor:pointer; white-space:nowrap; border-radius:0; transition:all .2s;">
                    <i class="bi bi-stars"></i><span class="d-none d-md-inline">KI-Suche</span>
                </button>
                <div style="flex:1; display:flex; align-items:center; border:1.5px solid var(--mc-border,#ddd); border-left:none; border-radius:0 var(--mc-radius-sm,8px) var(--mc-radius-sm,8px) 0; background:var(--mc-bg,#f5f5f5); height:42px; position:relative; overflow:hidden; transition:border-color .2s;"
                     id="topbarSearchBar">
                    <div id="topbarLocked" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:.45rem;background:var(--mc-bg,#f5f5f5);color:var(--mc-text-muted,#999);font-size:.84rem;font-weight:500;z-index:2;pointer-events:none;">
                        <i class="bi bi-lock"></i><span>Suchmethode w&auml;hlen</span>
                    </div>
                    <input id="topbarSearchInput" name="q" type="text" disabled
                           style="flex:1;border:none;background:transparent;color:var(--mc-text,#333);font-size:.88rem;outline:none;padding:0 .75rem;height:100%;font-family:inherit;" />
                    <button type="submit" id="topbarSubmit" disabled title="Suchen"
                            style="flex-shrink:0;width:38px;height:100%;border:none;background:transparent;color:var(--mc-text-muted,#999);font-size:1.3rem;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-arrow-right-circle-fill"></i>
                    </button>
                </div>
            </form>

            <div class="mc-topbar-right" style="flex-shrink:0;">
                <span class="mc-topbar-date d-none d-md-inline">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd.MM.yyyy")
                </span>
                <button class="mc-theme-toggle" id="themeToggle" title="Dark Mode umschalten">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
                <span class="d-none d-md-inline">@User.Identity.Name</span>
            </div>
        </header>

        <div class="mc-content" style="padding-bottom:0; padding-top:0.75rem; min-height:0; flex:none;">
            @if (TempData["Erfolg"] is string er)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @er
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Fehler"] is string fe)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i> @fe
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <main class="mc-content" role="main">
            @RenderBody()
        </main>

        <footer class="mc-footer">
            <span>&copy; @DateTime.Now.Year Merkur Privatbank KGaA &mdash; Organisationshandbuch</span>
        </footer>
    </div>

    <div id="sidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:199;" onclick="closeSidebar()"></div>

    <!-- ===== KI-Assistent Chat-Modal ===== -->
    <button id="aiFab" onclick="aiOeffnen()" title="KI-Assistent öffnen"
            style="position:fixed; right:1.25rem; bottom:1.25rem; z-index:995; width:56px; height:56px; border-radius:50%; border:none; background:linear-gradient(135deg, var(--mc-navy), #2c3e64); color:var(--mc-gold); box-shadow:var(--mc-shadow-lg); cursor:pointer; font-size:1.5rem; display:flex; align-items:center; justify-content:center;">
        <i class="bi bi-stars"></i>
    </button>

    <div id="aiModal" role="dialog" aria-label="KI-Assistent"
         style="display:none; position:fixed; right:1.25rem; bottom:1.25rem; width:min(500px, calc(100vw - 2rem)); height:min(70vh, calc(100vh - 2rem)); min-width:320px; min-height:350px; z-index:1000; background:var(--mc-surface); border:1px solid var(--mc-border); border-radius:var(--mc-radius); box-shadow:0 8px 32px rgba(0,0,0,.2); flex-direction:column; overflow:hidden; resize:both;">
        <div id="aiHeader" style="padding:.75rem 1rem; background:linear-gradient(135deg, var(--mc-navy), #2c3e64); color:#fff; display:flex; align-items:center; justify-content:space-between; cursor:move; user-select:none;">
            <div style="display:flex; align-items:center; gap:.5rem;">
                <i class="bi bi-stars" style="color:var(--mc-gold); font-size:1.25rem;"></i>
                <strong>KI-Assistent</strong>
                <span style="font-size:.75rem; opacity:.8;">OHB-Portal</span>
            </div>
            <div style="display:flex; gap:.25rem;">
                <button onclick="aiPopout()" title="In eigenem Fenster &ouml;ffnen"
                        style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                    <i class="bi bi-box-arrow-up-right"></i>
                </button>
                <button onclick="aiMaximieren()" title="Maximieren/Verkleinern"
                        style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                    <i class="bi bi-arrows-fullscreen" id="aiMaxIcon"></i>
                </button>
                <button onclick="aiVerlaufLeeren()" title="Verlauf leeren"
                        style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
                <button onclick="aiSchliessen()" title="Schlie&szlig;en"
                        style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <div id="aiNachrichten" style="flex:1; overflow-y:auto; padding:1rem; background:var(--mc-bg); display:flex; flex-direction:column; gap:.5rem;">
            <div class="ai-msg ai-msg-assistant">
                <div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm); max-width:85%;">
                    <div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>
                    Hallo! Ich helfe Ihnen, Dokumente, Richtlinien und Inhalte im OHB-Portal zu finden.<br/><br/>
                    <div style="background:rgba(0,81,90,0.06); border-radius:8px; padding:.6rem .8rem; margin-bottom:.5rem; font-size:.82rem;">
                        <i class="bi bi-info-circle" style="color:var(--mc-primary);"></i>
                        <strong>Tipp:</strong> Sie k&ouml;nnen Ihre Fragen entweder hier oder oben in der Suchleiste mit <strong>KI-Suche</strong> stellen.
                    </div>
                    <small>Beispiele:</small>
                    <ul style="margin:.5rem 0 0 1rem; padding:0; font-size:.85rem;">
                        <li>&bdquo;Finde Dokumente zu Compliance&ldquo;</li>
                        <li>&bdquo;Was steht in Dokument #42?&ldquo;</li>
                        <li>&bdquo;Zeig mir die zuletzt ge&auml;nderten Dokumente&ldquo;</li>
                        <li>&bdquo;Welche Kapitel gibt es?&ldquo;</li>
                    </ul>
                </div>
            </div>
        </div>

        <div style="padding:.75rem; border-top:1px solid var(--mc-border); background:var(--mc-surface);">
            <div style="display:flex; gap:.5rem;">
                <input type="text" id="aiInput" placeholder="Frage eingeben… (Enter zum Senden)"
                       onkeydown="aiInputKeydown(event)"
                       style="flex:1; padding:.5rem .75rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); background:var(--mc-bg); color:var(--mc-text);" />
                <button id="aiSendBtn" onclick="aiSendenAusModal()"
                        style="padding:.5rem 1rem; border:none; border-radius:var(--mc-radius-sm); background:var(--mc-navy); color:var(--mc-gold); cursor:pointer;">
                    <i class="bi bi-send"></i>
                </button>
            </div>
            <div style="font-size:.7rem; color:var(--mc-text-muted); margin-top:.35rem;">
                Antworten basieren auf Portal-Daten. Bitte Wichtiges im Dokument verifizieren.
            </div>
        </div>
    </div>

    <style>
        .ai-msg-user { align-self:flex-end; max-width:85%; }
        .ai-msg-assistant { align-self:flex-start; max-width:90%; }
        .ai-msg-bubble { word-wrap:break-word; line-height:1.45; font-size:.9rem; }
        .ai-msg-user .ai-msg-bubble { background:linear-gradient(135deg, var(--mc-navy), #2c3e64) !important; color:#fff !important; border-radius:var(--mc-radius-sm); padding:.6rem .75rem; }
        .ai-msg-bubble p:last-child { margin-bottom:0; }
        .ai-msg-bubble pre { background:rgba(0,0,0,0.05); padding:.4rem; border-radius:4px; overflow-x:auto; font-size:.8rem; }
        .ai-msg-bubble code { background:rgba(0,0,0,0.06); padding:.1rem .25rem; border-radius:3px; font-size:.85em; }
        .ai-msg-bubble ul, .ai-msg-bubble ol { margin:.25rem 0 .25rem 1.25rem; padding:0; }
        .ai-msg-bubble a { color:var(--mc-primary); text-decoration:underline; }
        .ai-typing-dots { display:inline-flex; gap:3px; }
        .ai-typing-dots span { width:6px; height:6px; border-radius:50%; background:var(--mc-text-muted); animation:aiDot 1.2s infinite ease-in-out; }
        .ai-typing-dots span:nth-child(2) { animation-delay:.15s; }
        .ai-typing-dots span:nth-child(3) { animation-delay:.3s; }
        @@keyframes aiDot { 0%, 60%, 100% { opacity:.3; transform:translateY(0); } 30% { opacity:1; transform:translateY(-3px); } }
        .ai-msg-bubble button:hover { opacity:.85; }
        #aiModal { resize:both; overflow:hidden; direction:ltr; }
        #aiModal.ai-maximized {
            width:calc(100vw - 2rem) !important; height:calc(100vh - 2rem) !important;
            right:1rem !important; bottom:1rem !important;
            border-radius:var(--mc-radius) !important; resize:none !important;
        }
    </style>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script>
    (function () {
        const stored = localStorage.getItem('mc-theme') || 'light';
        document.documentElement.setAttribute('data-theme', stored);
        updateIcon(stored);
    })();
    document.getElementById('themeToggle')?.addEventListener('click', function () {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mc-theme', next);
        updateIcon(next);
    });
    function updateIcon(t) {
        const i = document.getElementById('themeIcon');
        if (i) i.className = t === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }
    document.getElementById('sidebarToggle')?.addEventListener('click', function () {
        const s = document.getElementById('mcSidebar');
        const o = document.getElementById('sidebarOverlay');
        s.classList.toggle('open');
        o.style.display = s.classList.contains('open') ? 'block' : 'none';
    });
    function closeSidebar() {
        document.getElementById('mcSidebar')?.classList.remove('open');
        document.getElementById('sidebarOverlay').style.display = 'none';
    }

    // ===== KI-Assistent =====
    let aiVerlauf = [];
    let aiBesetzt = false;

    function aiOeffnen() {
        const m = document.getElementById('aiModal');
        if (!m) return;
        m.style.display = 'flex';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'none';
        setTimeout(() => document.getElementById('aiInput')?.focus(), 50);
    }

    let aiMax = false;
    let aiPrevStyle = {};

    function aiSchliessen() {
        const m = document.getElementById('aiModal');
        if (m) { m.style.display = 'none'; m.classList.remove('ai-maximized'); }
        aiMax = false;
        const icon = document.getElementById('aiMaxIcon');
        if (icon) icon.className = 'bi bi-arrows-fullscreen';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'flex';
    }

    function aiMaximieren() {
        const m = document.getElementById('aiModal');
        const icon = document.getElementById('aiMaxIcon');
        aiMax = !aiMax;
        if (aiMax) {
            aiPrevStyle = { width:m.style.width, height:m.style.height, right:m.style.right, bottom:m.style.bottom, top:m.style.top, left:m.style.left };
            m.classList.add('ai-maximized');
            m.style.top = ''; m.style.left = '';
            icon.className = 'bi bi-fullscreen-exit';
        } else {
            m.classList.remove('ai-maximized');
            Object.assign(m.style, aiPrevStyle);
            icon.className = 'bi bi-arrows-fullscreen';
        }
    }

    // Drag am Header
    (function() {
        var header = document.getElementById('aiHeader');
        var modal = document.getElementById('aiModal');
        if (!header || !modal) return;
        var dragging = false, startX, startY, startRight, startBottom;
        header.addEventListener('mousedown', function(e) {
            if (e.target.closest('button') || aiMax) return;
            dragging = true;
            startX = e.clientX; startY = e.clientY;
            var rect = modal.getBoundingClientRect();
            startRight = window.innerWidth - rect.right;
            startBottom = window.innerHeight - rect.bottom;
            modal.style.transition = 'none';
            e.preventDefault();
        });
        document.addEventListener('mousemove', function(e) {
            if (!dragging) return;
            modal.style.right = Math.max(0, startRight - (e.clientX - startX)) + 'px';
            modal.style.bottom = Math.max(0, startBottom - (e.clientY - startY)) + 'px';
            modal.style.top = 'auto'; modal.style.left = 'auto';
        });
        document.addEventListener('mouseup', function() {
            if (dragging) { dragging = false; modal.style.transition = ''; }
        });
    })();

    function aiPopout() {
        var w = window.open('', 'OHB_KI', 'width=550,height=700,resizable=yes,scrollbars=no');
        if (!w) { alert('Popup wurde blockiert. Bitte erlauben Sie Popups f\u00fcr diese Seite.'); return; }
        var theme = document.documentElement.getAttribute('data-theme') || 'light';
        var petrol = theme === 'dark' ? '#5aabb5' : '#00515A';
        var gold = theme === 'dark' ? '#d4b47a' : '#C8A96E';
        var bg = theme === 'dark' ? '#111118' : '#f3f5f8';
        var surface = theme === 'dark' ? '#1c1c26' : '#ffffff';
        var border = theme === 'dark' ? '#2c2c3a' : '#e4e7eb';
        var text = theme === 'dark' ? '#d0d0dc' : '#4a5568';
        var textDark = theme === 'dark' ? '#e8e8f0' : '#1a202c';
        var textMuted = theme === 'dark' ? '#7a7a8a' : '#8895a7';
        var verlaufJson = JSON.stringify(aiVerlauf);
        w.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>KI-Assistent \u2013 OHB-Portal</title>'
            + '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">'
            + '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">'
            + '<style>'
            + '*{box-sizing:border-box;margin:0;padding:0}'
            + 'body{font-family:Inter,system-ui,sans-serif;background:'+bg+';color:'+text+';height:100vh;display:flex;flex-direction:column;}'
            + '.header{padding:.75rem 1rem;background:linear-gradient(135deg,'+petrol+',#2c3e64);color:#fff;display:flex;align-items:center;gap:.5rem;}'
            + '.header i.star{color:'+gold+';font-size:1.15rem}'
            + '.chat{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.5rem;}'
            + '.msg-user{align-self:flex-end;max-width:85%}'
            + '.msg-ast{align-self:flex-start;max-width:90%}'
            + '.bubble{word-wrap:break-word;line-height:1.5;font-size:.9rem;padding:.65rem .8rem;border-radius:10px;}'
            + '.msg-user .bubble{background:'+petrol+';color:#fff;}'
            + '.msg-ast .bubble{background:'+surface+';border:1px solid '+border+';color:'+text+';}'
            + '.bubble strong{color:'+textDark+'}'
            + '.bubble p:last-child{margin-bottom:0}'
            + '.bubble ul,.bubble ol{margin:.25rem 0 .25rem 1.25rem;padding:0}'
            + '.bubble pre{background:rgba(0,0,0,.05);padding:.4rem;border-radius:4px;font-size:.8rem;white-space:pre-wrap}'
            + '.bubble code{background:rgba(0,0,0,.06);padding:.1rem .25rem;border-radius:3px;font-size:.85em}'
            + '.bubble a{color:'+petrol+';text-decoration:underline}'
            + '.label{font-size:.7rem;color:'+textMuted+';margin-bottom:.2rem;}'
            + '.bar{padding:.75rem;border-top:1px solid '+border+';background:'+surface+';display:flex;gap:.5rem;}'
            + '.bar input{flex:1;padding:.5rem .75rem;border:1px solid '+border+';border-radius:8px;background:'+bg+';color:'+text+';font-size:.9rem;outline:none;font-family:inherit;}'
            + '.bar input:focus{border-color:'+petrol+'}'
            + '.bar button{padding:.5rem 1rem;border:none;border-radius:8px;background:'+petrol+';color:#fff;cursor:pointer;font-size:1rem;}'
            + '.spin{width:18px;height:18px;border:2px solid '+border+';border-top-color:'+petrol+';border-radius:50%;animation:s .7s linear infinite;display:inline-block}'
            + '@@keyframes s{to{transform:rotate(360deg)}}'
            + '</style></head><body>'
            + '<div class="header"><i class="bi bi-stars star"></i><strong>KI-Assistent</strong><span style="font-size:.75rem;opacity:.8;">OHB-Portal</span></div>'
            + '<div class="chat" id="chat"></div>'
            + '<div class="bar"><input id="inp" placeholder="Frage eingeben\u2026" autofocus /><button onclick="senden()"><i class="bi bi-send"></i></button></div>'
            + '<script>'
            + 'var verlauf='+verlaufJson+';'
            + 'var besetzt=false;'
            + 'var parentOrigin='+JSON.stringify(window.location.origin)+';'
            + 'document.getElementById("inp").addEventListener("keydown",function(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();senden();}});'
            + 'function md(r){if(!r)return"";var s=r.replace(/&/g,"\\&amp;").replace(/</g,"\\&lt;").replace(/>/g,"\\&gt;");'
            + 's=s.replace(/```(\\w*)\\n?([\\s\\S]*?)```/g,function(m,l,c){return"<pre>"+c.trim()+"</pre>";});'
            + 's=s.replace(/`([^`]+)`/g,"<code>$1</code>");'
            + 's=s.replace(/\\*\\*([^*]+)\\*\\*/g,"<strong>$1</strong>");'
            + 's=s.replace(/(^|[^*])\\*([^*\\n]+)\\*/g,"$1<em>$2</em>");'
            + 's=s.replace(/^###\\s+(.+)$/gm,"<h5 style=\\"font-weight:600;margin:.5rem 0 .25rem\\">$1</h5>");'
            + 's=s.replace(/^##\\s+(.+)$/gm,"<h4 style=\\"font-weight:600;margin:.6rem 0 .3rem\\">$1</h4>");'
            + 's=s.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/g,"<a href=\\"$2\\" style=\\"color:'+petrol+';text-decoration:underline\\">$1</a>");'
            + 's=s.replace(/\\bKapitel\\s+#?(\\d{1,6})\\b/g,"<a href=\\""+window.location.origin+"/Kapitel/Index/$1\\" style=\\"color:'+petrol+';font-weight:600\\">Kapitel #$1</a>");'
            + 's=s.replace(/(^|[^&\\w])#(\\d{1,6})\\b/g,"$1<a href=\\""+window.location.origin+"/Dokumente/Details/$2\\" style=\\"color:'+petrol+';font-weight:600\\">#$2</a>");'
            + 's=s.replace(/(^|\\n)((?:\\d+\\.\\s+.+(?:\\n|$))+)/g,function(m,p,list){var items=list.split("\\n").map(function(l){return l.replace(/^\\d+\\.\\s+/,"").trim();}).filter(function(x){return x;});return p+"<ol>"+items.map(function(i){return"<li>"+i+"</li>";}).join("")+"</ol>";});'
            + 's=s.replace(/(^|\\n)(\\s*[-*]\\s+.+(?:\\n\\s*[-*]\\s+.+)*)/g,function(m,p,list){var items=list.split("\\n").map(function(l){return l.replace(/^\\s*[-*]\\s+/,"").trim();}).filter(function(x){return x;});return p+"<ul>"+items.map(function(i){return"<li>"+i+"</li>";}).join("")+"</ul>";});'
            + 'return s.split(/\\n{2,}/).map(function(p){p=p.trim();if(!p||/^<(h[1-6]|ul|ol|pre|table|hr)/.test(p))return p;return"<p style=\\"margin:0 0 .4rem\\">"+p.replace(/\\n/g,"<br/>")+"</p>";}).join("");'
            + '}'
            + 'function msg(rolle,text){var c=document.getElementById("chat");var w=document.createElement("div");w.className=rolle==="user"?"msg-user":"msg-ast";var b=document.createElement("div");b.className="bubble";'
            + 'if(rolle==="assistant"){b.innerHTML="<div class=\\"label\\">KI-Assistent</div>"+md(text);}else{b.textContent=text;}'
            + 'w.appendChild(b);c.appendChild(w);c.scrollTop=c.scrollHeight;}'
            + 'if(verlauf.length){verlauf.forEach(function(v){msg(v.rolle==="assistant"?"assistant":"user",v.text);});}else{msg("assistant","Hallo! Ich helfe dir, Dokumente und Inhalte im OHB-Portal zu finden.");}'
            + 'async function senden(){var inp=document.getElementById("inp");var frage=inp.value.trim();if(!frage||besetzt)return;besetzt=true;inp.value="";msg("user",frage);'
            + 'var c=document.getElementById("chat");var t=document.createElement("div");t.className="msg-ast";t.innerHTML="<div class=\\"bubble\\"><div class=\\"spin\\"></div> Antwort wird erstellt\\u2026</div>";c.appendChild(t);c.scrollTop=c.scrollHeight;'
            + 'try{var r=await fetch(parentOrigin+"/AiAssistent/Fragen",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({frage:frage,verlauf:verlauf}),credentials:"include"});'
            + 'var d=await r.json();t.remove();if(d.error){msg("assistant","**Fehler:** "+d.error);}else if(d.aktion){msg("assistant","Die Aktion **"+d.aktion.typ+"** kann nur im Hauptfenster ausgef\\u00fchrt werden. Bitte dort best\\u00e4tigen.");}else{var a=d.antwort||"(leer)";msg("assistant",a);verlauf.push({rolle:"user",text:frage});verlauf.push({rolle:"assistant",text:a});if(verlauf.length>10)verlauf=verlauf.slice(-10);}'
            + '}catch(e){t.remove();msg("assistant","**Fehler:** Verbindung fehlgeschlagen.");}finally{besetzt=false;inp.focus();}}'
            + '<\/script></body></html>');
        w.document.close();
        aiSchliessen();
    }

    function aiVerlaufLeeren() {
        aiVerlauf = [];
        const cont = document.getElementById('aiNachrichten');
        if (cont) cont.innerHTML = '<div class="ai-msg ai-msg-assistant"><div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>Verlauf geleert. Stelle eine neue Frage!</div></div>';
    }

    // ===== Topbar Suchleiste: Mode-Toggle =====
    function topbarSetMode(mode) {
        document.getElementById('topbarMode').value = mode;
        var input = document.getElementById('topbarSearchInput');
        var submit = document.getElementById('topbarSubmit');
        var locked = document.getElementById('topbarLocked');
        locked.style.display = 'none';
        input.disabled = false;
        submit.disabled = false;
        document.querySelectorAll('.topbar-pick-btn').forEach(function(b) {
            b.style.background = 'var(--mc-bg-card,#fff)';
            b.style.color = 'var(--mc-text-muted,#999)';
            b.style.borderColor = 'var(--mc-border,#ddd)';
        });
        if (mode === 'ai') {
            input.placeholder = 'KI-Suche: z.B. Welche Dokumente behandeln Sicherheit?';
            var btn = document.querySelector('.topbar-pick-ai');
            btn.style.background = 'linear-gradient(135deg,#6a5a8a,#8a6abf)';
            btn.style.color = '#fff';
            btn.style.borderColor = '#6a5a8a';
            submit.style.color = '#8a6abf';
        } else {
            input.placeholder = 'Suche ohne KI: Titel, Beschreibung, Inhalt, Tags ...';
            var btn = document.querySelector('.topbar-pick-smart');
            btn.style.background = 'var(--mc-navy,#00515A)';
            btn.style.color = '#fff';
            btn.style.borderColor = 'var(--mc-navy,#00515A)';
            submit.style.color = 'var(--mc-navy,#00515A)';
        }
        input.focus();
    }

    // ===== Topbar KI-Suche entfernt – läuft jetzt über /Search =====

    function topbarKiSenden() {}

    /*  Legacy-Code entfernt
    if (false) {
        var dd = null;
        var data = {};
        if (data.error) {
                dd.innerHTML = '<div class="topbar-ki-header"><i class="bi bi-stars"></i> KI-Assistent</div><div class="ai-msg-bubble">Diese Aktion erfordert eine Best&auml;tigung. Bitte nutzen Sie den <strong>Chat unten rechts</strong> (<i class="bi bi-stars"></i>) f&uuml;r Aktionen wie Dokumente erstellen oder bearbeiten.</div>';
            } else {
                dd.innerHTML = '<div class="topbar-ki-header"><i class="bi bi-stars"></i> KI-Assistent</div><div class="ai-msg-bubble">' + aiMarkdown(data.antwort || '') + '</div>';
            }
        } catch {
            dd.innerHTML = '<div class="topbar-ki-header"><i class="bi bi-stars"></i> KI-Assistent</div><div style="color:var(--mc-warning);">Verbindung fehlgeschlagen.</div>';
        } finally {
            topbarBesetzt = false;
        }
    }
    */

    function aiInputKeydown(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            aiSendenAusModal();
        }
    }

    function aiSendenAusModal() {
        const inp = document.getElementById('aiInput');
        if (!inp) return;
        const frage = inp.value.trim();
        if (!frage || aiBesetzt) return;
        inp.value = '';
        aiSenden(frage);
    }

    async function aiSenden(frage, bestaetigeAktion) {
        if (aiBesetzt) return;
        aiBesetzt = true;
        const btn = document.getElementById('aiSendBtn');
        if (btn) btn.disabled = true;

        if (!bestaetigeAktion) aiNachrichtAnzeigen('user', frage);
        const typingEl = aiTippenZeigen();

        try {
            const payload = bestaetigeAktion
                ? { frage: '', verlauf: aiVerlauf, bestaetigeAktion }
                : { frage, verlauf: aiVerlauf };

            const resp = await fetch('/AiAssistent/Fragen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await resp.json();
            typingEl?.remove();

            if (data.error) {
                aiNachrichtAnzeigen('assistant', '**Fehler:** ' + data.error);
            } else if (data.aktion) {
                aiBestaetigungAnzeigen(data.aktion, frage);
                aiVerlauf.push({ rolle: 'user', text: frage });
            } else {
                const antwort = data.antwort || '(leere Antwort)';
                aiNachrichtAnzeigen('assistant', antwort);
                if (!bestaetigeAktion) aiVerlauf.push({ rolle: 'user', text: frage });
                aiVerlauf.push({ rolle: 'assistant', text: antwort });
                if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
            }
        } catch (err) {
            typingEl?.remove();
            aiNachrichtAnzeigen('assistant', '**Fehler:** Verbindung zum KI-Dienst fehlgeschlagen.');
        } finally {
            aiBesetzt = false;
            if (btn) btn.disabled = false;
            document.getElementById('aiInput')?.focus();
        }
    }

    function aiBestaetigungAnzeigen(aktion, originalFrage) {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-assistant';
        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        bubble.style.cssText = 'background:var(--mc-surface); border:2px solid var(--mc-gold); padding:.75rem; border-radius:var(--mc-radius-sm);';

        const label = document.createElement('div');
        label.style.cssText = 'font-size:.75rem; color:var(--mc-gold); margin-bottom:.5rem; font-weight:600;';
        label.innerHTML = '<i class="bi bi-lightning-charge-fill"></i> Aktion bestätigen';
        bubble.appendChild(label);

        const desc = document.createElement('div');
        desc.innerHTML = aiMarkdown(aktion.beschreibung);
        desc.style.marginBottom = '.75rem';
        bubble.appendChild(desc);

        const btnRow = document.createElement('div');
        btnRow.style.cssText = 'display:flex; gap:.5rem;';

        const btnJa = document.createElement('button');
        btnJa.textContent = 'Ja, ausführen';
        btnJa.style.cssText = 'padding:.4rem .75rem; border:none; border-radius:4px; background:var(--mc-success); color:#fff; cursor:pointer; font-size:.85rem;';
        btnJa.onclick = function() {
            btnRow.innerHTML = '<span style="color:var(--mc-text-muted); font-size:.85rem;"><i class="bi bi-check-circle"></i> Wird ausgeführt…</span>';
            aiSenden('', { typ: aktion.typ, parameter: aktion.parameter });
        };

        const btnNein = document.createElement('button');
        btnNein.textContent = 'Abbrechen';
        btnNein.style.cssText = 'padding:.4rem .75rem; border:1px solid var(--mc-border); border-radius:4px; background:transparent; color:var(--mc-text); cursor:pointer; font-size:.85rem;';
        btnNein.onclick = function() {
            btnRow.innerHTML = '<span style="color:var(--mc-text-muted); font-size:.85rem;"><i class="bi bi-x-circle"></i> Abgebrochen</span>';
        };

        btnRow.appendChild(btnJa);
        btnRow.appendChild(btnNein);
        bubble.appendChild(btnRow);
        wrap.appendChild(bubble);
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
    }

    function aiNachrichtAnzeigen(rolle, text) {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-' + rolle;
        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        if (rolle === 'assistant') {
            bubble.style.background = 'var(--mc-surface)';
            bubble.style.border = '1px solid var(--mc-border)';
            bubble.style.padding = '.75rem';
            bubble.style.borderRadius = 'var(--mc-radius-sm)';
            const label = document.createElement('div');
            label.style.cssText = 'font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;';
            label.textContent = 'KI-Assistent';
            bubble.appendChild(label);
            const body = document.createElement('div');
            body.innerHTML = aiMarkdown(text);
            bubble.appendChild(body);
        } else {
            bubble.textContent = text;
        }
        wrap.appendChild(bubble);
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
    }

    function aiTippenZeigen() {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return null;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-assistant';
        wrap.innerHTML = '<div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div class="ai-typing-dots"><span></span><span></span><span></span></div></div>';
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
        return wrap;
    }

    function aiEscapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function aiMarkdown(raw) {
        if (!raw) return '';
        let s = aiEscapeHtml(raw);
        // Code blocks
        s = s.replace(/```([\s\S]*?)```/g, (m, code) => '<pre>' + code.trim() + '</pre>');
        // Inline code
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        // Markdown-Links [text](url) zwischenspeichern, damit Auto-Linking sie nicht verschachtelt
        const linkPh = [];
        s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (m, t, u) => {
            linkPh.push('<a href="' + u + '" style="color:var(--mc-primary);text-decoration:underline;">' + t + '</a>');
            return '\x01L' + (linkPh.length - 1) + '\x01';
        });
        // Kapitel-Referenzen klickbar: "Kapitel #3" oder "Kapitel 3"
        s = s.replace(/\bKapitel\s+#?(\d{1,6})\b/g, '<a href="/Kapitel/Index/$1" style="color:var(--mc-primary);text-decoration:underline;">Kapitel #$1</a>');
        // Dokument-IDs klickbar: #42
        s = s.replace(/(^|[^&\w])#(\d{1,6})\b/g, '$1<a href="/Dokumente/Details/$2" style="color:var(--mc-primary);text-decoration:underline;">#$2</a>');
        // Platzhalter durch echte Markdown-Links ersetzen
        s = s.replace(/\x01L(\d+)\x01/g, (m, i) => linkPh[+i]);
        // Headings
        s = s.replace(/^###\s+(.+)$/gm, '<h6 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h6>');
        s = s.replace(/^##\s+(.+)$/gm, '<h5 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h5>');
        s = s.replace(/^#\s+(.+)$/gm, '<h4 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h4>');
        // Bold / Italic
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
        // Lists: - or *
        s = s.replace(/(^|\n)(\s*[-*]\s+.+(?:\n\s*[-*]\s+.+)*)/g, (m, p, list) => {
            const items = list.split(/\n/).map(l => l.replace(/^\s*[-*]\s+/, '').trim()).filter(x => x);
            return p + '<ul>' + items.map(i => '<li>' + i + '</li>').join('') + '</ul>';
        });
        // Paragraphs on double newline
        const parts = s.split(/\n{2,}/).map(p => {
            if (/^<(h[1-6]|ul|ol|pre|blockquote)/.test(p.trim())) return p;
            return '<p style="margin:0 0 .4rem;">' + p.replace(/\n/g, '<br/>') + '</p>';
        });
        return parts.join('');
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
