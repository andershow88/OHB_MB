@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    bool istEditor = User.IsInRole("Editor") || User.IsInRole("Admin") || User.IsInRole("Bereichsverantwortlicher");
    bool istApprover = User.IsInRole("Approver") || User.IsInRole("Admin");
    bool istAdmin = User.IsInRole("Admin");
}
<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Organisationshandbuch</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/merkur.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('mc-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>
<body class="mc-body">

@if (User.Identity?.IsAuthenticated == true)
{
    <aside class="mc-sidebar" id="mcSidebar">
        <div class="mc-sidebar-brand">
            <a asp-controller="Dashboard" asp-action="Index" class="mc-logo" style="text-decoration:none">
                <img src="~/images/merkur-logo.svg" alt="Merkur Privatbank" class="mc-logo-img" />
                <div class="mc-logo-title">Organisations­handbuch</div>
                <div class="mc-logo-subtitle">MERKUR PRIVATBANK KGaA</div>
            </a>
        </div>

        <div class="mc-sidebar-bank">
            <div class="mc-sidebar-bank-label">Angemeldet als</div>
            <div class="mc-sidebar-bank-name">@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</div>
            <div class="mc-sidebar-bank-user">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "–")</div>
        </div>

        <ul class="mc-nav">
            <li class="mc-nav-item">
                <a asp-controller="Dashboard" asp-action="Index"
                   class="mc-nav-link @(ctrl == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Kapitel" asp-action="Index"
                   class="mc-nav-link @(ctrl == "Kapitel" ? "active" : "")">
                    <i class="bi bi-diagram-3"></i> <span>Themenbaum</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Dokumente" asp-action="Index"
                   class="mc-nav-link @(ctrl == "Dokumente" && action == "Index" ? "active" : "")">
                    <i class="bi bi-file-earmark-text"></i> <span>Dokumente</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Freigaben" asp-action="Meine"
                   class="mc-nav-link @(ctrl == "Freigaben" ? "active" : "")">
                    <i class="bi bi-check2-square"></i> <span>Meine Freigaben</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Kenntnisnahmen" asp-action="Meine"
                   class="mc-nav-link @(ctrl == "Kenntnisnahmen" ? "active" : "")">
                    <i class="bi bi-eye"></i> <span>Meine Kenntnisnahmen</span>
                </a>
            </li>
            @if (istAdmin)
            {
                <li class="mc-nav-item" style="margin-top:.5rem; border-top:1px solid var(--mc-border); padding-top:.5rem;">
                    <a asp-controller="Admin" asp-action="Index"
                       class="mc-nav-link @(ctrl == "Admin" ? "active" : "")">
                        <i class="bi bi-shield-lock"></i> <span>Administration</span>
                    </a>
                </li>
            }
            <li class="mc-nav-item" style="@(istAdmin ? "" : "margin-top:.5rem; border-top:1px solid var(--mc-border); padding-top:.5rem;")">
                <a asp-controller="Dokumente" asp-action="Archiv"
                   class="mc-nav-link @(ctrl == "Dokumente" && action == "Archiv" ? "active" : "")">
                    <i class="bi bi-archive"></i> <span>Archiv</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Dokumente" asp-action="Papierkorb"
                   class="mc-nav-link @(ctrl == "Dokumente" && action == "Papierkorb" ? "active" : "")">
                    <i class="bi bi-trash"></i> <span>Papierkorb</span>
                </a>
            </li>
        </ul>

        <!-- Abmelden-Button auskommentiert (Auto-Login aktiv)
        <div class="mc-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="mc-logout-btn">
                    <i class="bi bi-box-arrow-right"></i> Abmelden
                </button>
            </form>
        </div>
        -->
    </aside>

    <div class="mc-main">
        <header class="mc-topbar" style="gap:.75rem;">
            <button class="mc-sidebar-toggle d-lg-none" id="sidebarToggle" aria-label="Menü öffnen">
                <i class="bi bi-list"></i>
            </button>
            <div class="mc-breadcrumb">
                @if (ViewData["Breadcrumb"] != null) { @Html.Raw(ViewData["Breadcrumb"]) }
            </div>

            <div class="ai-topbar-search" style="flex:1; margin-right:auto; margin-left:.5rem; position:relative;">
                <i class="bi bi-stars" style="position:absolute; left:.85rem; top:50%; transform:translateY(-50%); color:var(--mc-gold); pointer-events:none; font-size:1.1rem;"></i>
                <input type="text" id="aiTopbarInput"
                       placeholder='Frag den KI-Assistenten… (z.B. "Finde Dokumente zu Compliance")'
                       onkeydown="aiTopbarKeydown(event)"
                       style="width:100%; padding:.6rem 1rem .6rem 2.5rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); background:var(--mc-surface); color:var(--mc-text); font-size:.95rem;" />
            </div>

            <div class="mc-topbar-right" style="flex-shrink:0;">
                <span class="mc-topbar-date d-none d-md-inline">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd.MM.yyyy")
                </span>
                <button class="mc-theme-toggle" id="themeToggle" title="Dark Mode umschalten">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
                <span class="d-none d-md-inline">@User.Identity.Name</span>
            </div>
        </header>

        <div class="mc-content" style="padding-bottom:0; padding-top:0.75rem; min-height:0; flex:none;">
            @if (TempData["Erfolg"] is string er)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @er
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Fehler"] is string fe)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i> @fe
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <main class="mc-content" role="main">
            @RenderBody()
        </main>

        <footer class="mc-footer">
            <span>&copy; @DateTime.Now.Year Merkur Privatbank KGaA &mdash; Organisationshandbuch</span>
        </footer>
    </div>

    <div id="sidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:199;" onclick="closeSidebar()"></div>

    <!-- ===== KI-Assistent Chat-Modal ===== -->
    <button id="aiFab" onclick="aiOeffnen()" title="KI-Assistent öffnen"
            style="position:fixed; right:1.25rem; bottom:1.25rem; z-index:995; width:56px; height:56px; border-radius:50%; border:none; background:linear-gradient(135deg, var(--mc-navy), #2c3e64); color:var(--mc-gold); box-shadow:var(--mc-shadow-lg); cursor:pointer; font-size:1.5rem; display:flex; align-items:center; justify-content:center;">
        <i class="bi bi-stars"></i>
    </button>

    <div id="aiModal" role="dialog" aria-label="KI-Assistent"
         style="display:none; position:fixed; right:1.25rem; bottom:1.25rem; width:min(420px, calc(100vw - 2rem)); height:min(620px, calc(100vh - 2rem)); z-index:1000; background:var(--mc-surface); border:1px solid var(--mc-border); border-radius:var(--mc-radius); box-shadow:var(--mc-shadow-lg); flex-direction:column; overflow:hidden;">
        <div style="padding:.75rem 1rem; background:linear-gradient(135deg, var(--mc-navy), #2c3e64); color:#fff; display:flex; align-items:center; justify-content:space-between;">
            <div style="display:flex; align-items:center; gap:.5rem;">
                <i class="bi bi-stars" style="color:var(--mc-gold); font-size:1.25rem;"></i>
                <strong>KI-Assistent</strong>
                <span style="font-size:.75rem; opacity:.8;">OHB-Portal</span>
            </div>
            <div style="display:flex; gap:.25rem;">
                <button onclick="aiVerlaufLeeren()" title="Verlauf leeren"
                        style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
                <button onclick="aiSchliessen()" title="Schließen"
                        style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <div id="aiNachrichten" style="flex:1; overflow-y:auto; padding:1rem; background:var(--mc-bg); display:flex; flex-direction:column; gap:.5rem;">
            <div class="ai-msg ai-msg-assistant">
                <div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm); max-width:85%;">
                    <div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>
                    Hallo! Ich helfe dir, Dokumente, Richtlinien und Inhalte im OHB-Portal zu finden.<br/>
                    <small>Beispiele:</small>
                    <ul style="margin:.5rem 0 0 1rem; padding:0; font-size:.85rem;">
                        <li>"Finde Dokumente zu Compliance"</li>
                        <li>"Was steht in Dokument #42?"</li>
                        <li>"Zeig mir die zuletzt geänderten Dokumente"</li>
                        <li>"Welche Kapitel gibt es?"</li>
                    </ul>
                </div>
            </div>
        </div>

        <div style="padding:.75rem; border-top:1px solid var(--mc-border); background:var(--mc-surface);">
            <div style="display:flex; gap:.5rem;">
                <input type="text" id="aiInput" placeholder="Frage eingeben… (Enter zum Senden)"
                       onkeydown="aiInputKeydown(event)"
                       style="flex:1; padding:.5rem .75rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); background:var(--mc-bg); color:var(--mc-text);" />
                <button id="aiSendBtn" onclick="aiSendenAusModal()"
                        style="padding:.5rem 1rem; border:none; border-radius:var(--mc-radius-sm); background:var(--mc-navy); color:var(--mc-gold); cursor:pointer;">
                    <i class="bi bi-send"></i>
                </button>
            </div>
            <div style="font-size:.7rem; color:var(--mc-text-muted); margin-top:.35rem;">
                Antworten basieren auf Portal-Daten. Bitte Wichtiges im Dokument verifizieren.
            </div>
        </div>
    </div>

    <style>
        .ai-msg-user { align-self:flex-end; max-width:85%; }
        .ai-msg-assistant { align-self:flex-start; max-width:90%; }
        .ai-msg-bubble { word-wrap:break-word; line-height:1.45; font-size:.9rem; }
        .ai-msg-user .ai-msg-bubble { background:linear-gradient(135deg, var(--mc-navy), #2c3e64) !important; color:#fff !important; border-radius:var(--mc-radius-sm); padding:.6rem .75rem; }
        .ai-msg-bubble p:last-child { margin-bottom:0; }
        .ai-msg-bubble pre { background:rgba(0,0,0,0.05); padding:.4rem; border-radius:4px; overflow-x:auto; font-size:.8rem; }
        .ai-msg-bubble code { background:rgba(0,0,0,0.06); padding:.1rem .25rem; border-radius:3px; font-size:.85em; }
        .ai-msg-bubble ul, .ai-msg-bubble ol { margin:.25rem 0 .25rem 1.25rem; padding:0; }
        .ai-msg-bubble a { color:var(--mc-primary); text-decoration:underline; }
        .ai-typing-dots { display:inline-flex; gap:3px; }
        .ai-typing-dots span { width:6px; height:6px; border-radius:50%; background:var(--mc-text-muted); animation:aiDot 1.2s infinite ease-in-out; }
        .ai-typing-dots span:nth-child(2) { animation-delay:.15s; }
        .ai-typing-dots span:nth-child(3) { animation-delay:.3s; }
        @@keyframes aiDot { 0%, 60%, 100% { opacity:.3; transform:translateY(0); } 30% { opacity:1; transform:translateY(-3px); } }
        .ai-msg-bubble button:hover { opacity:.85; }
    </style>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script>
    (function () {
        const stored = localStorage.getItem('mc-theme') || 'light';
        document.documentElement.setAttribute('data-theme', stored);
        updateIcon(stored);
    })();
    document.getElementById('themeToggle')?.addEventListener('click', function () {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mc-theme', next);
        updateIcon(next);
    });
    function updateIcon(t) {
        const i = document.getElementById('themeIcon');
        if (i) i.className = t === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }
    document.getElementById('sidebarToggle')?.addEventListener('click', function () {
        const s = document.getElementById('mcSidebar');
        const o = document.getElementById('sidebarOverlay');
        s.classList.toggle('open');
        o.style.display = s.classList.contains('open') ? 'block' : 'none';
    });
    function closeSidebar() {
        document.getElementById('mcSidebar')?.classList.remove('open');
        document.getElementById('sidebarOverlay').style.display = 'none';
    }

    // ===== KI-Assistent =====
    let aiVerlauf = [];
    let aiBesetzt = false;

    function aiOeffnen() {
        const m = document.getElementById('aiModal');
        if (!m) return;
        m.style.display = 'flex';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'none';
        setTimeout(() => document.getElementById('aiInput')?.focus(), 50);
    }

    function aiSchliessen() {
        const m = document.getElementById('aiModal');
        if (m) m.style.display = 'none';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'flex';
    }

    function aiVerlaufLeeren() {
        aiVerlauf = [];
        const cont = document.getElementById('aiNachrichten');
        if (cont) cont.innerHTML = '<div class="ai-msg ai-msg-assistant"><div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>Verlauf geleert. Stelle eine neue Frage!</div></div>';
    }

    function aiTopbarKeydown(e) {
        if (e.key === 'Enter') {
            const val = e.target.value.trim();
            if (!val) return;
            aiOeffnen();
            document.getElementById('aiInput').value = val;
            e.target.value = '';
            aiSendenAusModal();
        }
    }

    function aiInputKeydown(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            aiSendenAusModal();
        }
    }

    function aiSendenAusModal() {
        const inp = document.getElementById('aiInput');
        if (!inp) return;
        const frage = inp.value.trim();
        if (!frage || aiBesetzt) return;
        inp.value = '';
        aiSenden(frage);
    }

    async function aiSenden(frage, bestaetigeAktion) {
        if (aiBesetzt) return;
        aiBesetzt = true;
        const btn = document.getElementById('aiSendBtn');
        if (btn) btn.disabled = true;

        if (!bestaetigeAktion) aiNachrichtAnzeigen('user', frage);
        const typingEl = aiTippenZeigen();

        try {
            const payload = bestaetigeAktion
                ? { frage: '', verlauf: aiVerlauf, bestaetigeAktion }
                : { frage, verlauf: aiVerlauf };

            const resp = await fetch('/AiAssistent/Fragen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await resp.json();
            typingEl?.remove();

            if (data.error) {
                aiNachrichtAnzeigen('assistant', '**Fehler:** ' + data.error);
            } else if (data.aktion) {
                aiBestaetigungAnzeigen(data.aktion, frage);
                aiVerlauf.push({ rolle: 'user', text: frage });
            } else {
                const antwort = data.antwort || '(leere Antwort)';
                aiNachrichtAnzeigen('assistant', antwort);
                if (!bestaetigeAktion) aiVerlauf.push({ rolle: 'user', text: frage });
                aiVerlauf.push({ rolle: 'assistant', text: antwort });
                if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
            }
        } catch (err) {
            typingEl?.remove();
            aiNachrichtAnzeigen('assistant', '**Fehler:** Verbindung zum KI-Dienst fehlgeschlagen.');
        } finally {
            aiBesetzt = false;
            if (btn) btn.disabled = false;
            document.getElementById('aiInput')?.focus();
        }
    }

    function aiBestaetigungAnzeigen(aktion, originalFrage) {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-assistant';
        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        bubble.style.cssText = 'background:var(--mc-surface); border:2px solid var(--mc-gold); padding:.75rem; border-radius:var(--mc-radius-sm);';

        const label = document.createElement('div');
        label.style.cssText = 'font-size:.75rem; color:var(--mc-gold); margin-bottom:.5rem; font-weight:600;';
        label.innerHTML = '<i class="bi bi-lightning-charge-fill"></i> Aktion bestätigen';
        bubble.appendChild(label);

        const desc = document.createElement('div');
        desc.innerHTML = aiMarkdown(aktion.beschreibung);
        desc.style.marginBottom = '.75rem';
        bubble.appendChild(desc);

        const btnRow = document.createElement('div');
        btnRow.style.cssText = 'display:flex; gap:.5rem;';

        const btnJa = document.createElement('button');
        btnJa.textContent = 'Ja, ausführen';
        btnJa.style.cssText = 'padding:.4rem .75rem; border:none; border-radius:4px; background:var(--mc-success); color:#fff; cursor:pointer; font-size:.85rem;';
        btnJa.onclick = function() {
            btnRow.innerHTML = '<span style="color:var(--mc-text-muted); font-size:.85rem;"><i class="bi bi-check-circle"></i> Wird ausgeführt…</span>';
            aiSenden('', { typ: aktion.typ, parameter: aktion.parameter });
        };

        const btnNein = document.createElement('button');
        btnNein.textContent = 'Abbrechen';
        btnNein.style.cssText = 'padding:.4rem .75rem; border:1px solid var(--mc-border); border-radius:4px; background:transparent; color:var(--mc-text); cursor:pointer; font-size:.85rem;';
        btnNein.onclick = function() {
            btnRow.innerHTML = '<span style="color:var(--mc-text-muted); font-size:.85rem;"><i class="bi bi-x-circle"></i> Abgebrochen</span>';
        };

        btnRow.appendChild(btnJa);
        btnRow.appendChild(btnNein);
        bubble.appendChild(btnRow);
        wrap.appendChild(bubble);
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
    }

    function aiNachrichtAnzeigen(rolle, text) {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-' + rolle;
        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        if (rolle === 'assistant') {
            bubble.style.background = 'var(--mc-surface)';
            bubble.style.border = '1px solid var(--mc-border)';
            bubble.style.padding = '.75rem';
            bubble.style.borderRadius = 'var(--mc-radius-sm)';
            const label = document.createElement('div');
            label.style.cssText = 'font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;';
            label.textContent = 'KI-Assistent';
            bubble.appendChild(label);
            const body = document.createElement('div');
            body.innerHTML = aiMarkdown(text);
            bubble.appendChild(body);
        } else {
            bubble.textContent = text;
        }
        wrap.appendChild(bubble);
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
    }

    function aiTippenZeigen() {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return null;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-assistant';
        wrap.innerHTML = '<div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div class="ai-typing-dots"><span></span><span></span><span></span></div></div>';
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
        return wrap;
    }

    function aiEscapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function aiMarkdown(raw) {
        if (!raw) return '';
        let s = aiEscapeHtml(raw);
        // Code blocks
        s = s.replace(/```([\s\S]*?)```/g, (m, code) => '<pre>' + code.trim() + '</pre>');
        // Inline code
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        // Headings
        s = s.replace(/^###\s+(.+)$/gm, '<h6 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h6>');
        s = s.replace(/^##\s+(.+)$/gm, '<h5 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h5>');
        s = s.replace(/^#\s+(.+)$/gm, '<h4 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h4>');
        // Bold / Italic
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
        // Links [text](url)
        s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
        // Dokument-IDs klickbar: #42
        s = s.replace(/(^|[\s(])#(\d{1,6})\b/g, '$1<a href="/Dokumente/Details/$2">#$2</a>');
        // Lists: - or *
        s = s.replace(/(^|\n)(\s*[-*]\s+.+(?:\n\s*[-*]\s+.+)*)/g, (m, p, list) => {
            const items = list.split(/\n/).map(l => l.replace(/^\s*[-*]\s+/, '').trim()).filter(x => x);
            return p + '<ul>' + items.map(i => '<li>' + i + '</li>').join('') + '</ul>';
        });
        // Paragraphs on double newline
        const parts = s.split(/\n{2,}/).map(p => {
            if (/^<(h[1-6]|ul|ol|pre|blockquote)/.test(p.trim())) return p;
            return '<p style="margin:0 0 .4rem;">' + p.replace(/\n/g, '<br/>') + '</p>';
        });
        return parts.join('');
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
