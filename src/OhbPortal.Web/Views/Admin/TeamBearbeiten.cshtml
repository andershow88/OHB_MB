@model OhbPortal.Application.DTOs.TeamDetailDto
@{
    ViewData["Title"] = $"Team: {Model.Name}";
    var alleBenutzer = ViewBag.AlleBenutzer as IEnumerable<OhbPortal.Application.DTOs.BenutzerListeDto>
        ?? Enumerable.Empty<OhbPortal.Application.DTOs.BenutzerListeDto>();
    var mitgliedIds = Model.Mitglieder.Select(m => m.Id).ToHashSet();
}

<div class="mc-page-header">
    <div>
        <div style="font-size:0.82rem; color:var(--mc-text-muted); margin-bottom:0.4rem;">
            <a asp-action="Teams" style="color:var(--mc-primary);">Teams</a>
            <span style="margin:0 0.4rem;">/</span>
            <span>@Model.Name</span>
        </div>
        <h1 class="mc-page-title" style="font-size:1.25rem;">
            <i class="bi bi-diagram-2 me-2"></i>@Model.Name
            <span class="mc-badge @(Model.IstAktiv ? "badge-success" : "badge-secondary") ms-2">
                @(Model.IstAktiv ? "aktiv" : "deaktiviert")
            </span>
        </h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Teams" class="btn-mc-ghost"><i class="bi bi-arrow-left"></i> Zurück</a>
        <form asp-action="TeamLoeschen" asp-route-id="@Model.Id" method="post" style="display:inline;"
              onsubmit="return mcAsk(this, 'Team wirklich löschen?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-mc-ghost" style="color:var(--mc-danger);">
                <i class="bi bi-trash"></i> Löschen
            </button>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-pencil"></i> Stammdaten</h2>
            </div>
            <div class="mc-card-body">
                <form asp-action="TeamBearbeiten" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Teamname</label>
                        <input name="Name" class="form-control" required maxlength="150" value="@Model.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Beschreibung</label>
                        <textarea name="Beschreibung" class="form-control" rows="3" maxlength="500">@Model.Beschreibung</textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input name="IstAktiv" class="form-check-input" type="checkbox" value="true" id="aktivFlag" @(Model.IstAktiv ? "checked" : "") />
                        <label class="form-check-label" for="aktivFlag">Aktiv</label>
                    </div>
                    <button type="submit" class="btn-mc-primary"><i class="bi bi-check2 me-1"></i>Speichern</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-people"></i> Mitglieder (@Model.Mitglieder.Count)</h2>
            </div>
            <div class="mc-card-body">
                <form asp-action="TeamMitgliedHinzufuegen" method="post" class="row g-2 align-items-end mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="teamId" value="@Model.Id" />
                    <div class="col-md-8">
                        <label class="form-label fw-semibold small">Benutzer hinzufügen</label>
                        <select name="benutzerId" class="form-select form-select-sm" required>
                            <option value="">– Benutzer wählen –</option>
                            @foreach (var b in alleBenutzer.Where(u => !mitgliedIds.Contains(u.Id) && u.IstAktiv))
                            {
                                <option value="@b.Id">@b.Anzeigename (@b.Rolle)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn-mc-primary w-100" style="font-size:.82rem; padding:.35rem .5rem;">
                            <i class="bi bi-person-plus me-1"></i> Hinzufügen
                        </button>
                    </div>
                </form>

                @if (!Model.Mitglieder.Any())
                {
                    <p class="text-muted small mb-0">Noch keine Mitglieder.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var m in Model.Mitglieder)
                        {
                            <li class="d-flex align-items-center py-2 border-bottom" style="border-color:var(--mc-border)!important;">
                                <i class="bi bi-person-circle me-2" style="color:var(--mc-text-muted);"></i>
                                <div style="flex:1;">
                                    <div class="fw-semibold">@m.Anzeigename</div>
                                    <div class="small text-muted">@m.Rolle</div>
                                </div>
                                <form asp-action="TeamMitgliedEntfernen" method="post" style="display:inline;"
                                      onsubmit="return mcAsk(this, 'Mitglied entfernen?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="teamId" value="@Model.Id" />
                                    <input type="hidden" name="benutzerId" value="@m.Id" />
                                    <button type="submit" class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .45rem; color:var(--mc-danger);">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
