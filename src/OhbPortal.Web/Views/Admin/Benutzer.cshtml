@model IEnumerable<OhbPortal.Application.DTOs.BenutzerListeDto>
@{
    ViewData["Title"] = "Benutzer verwalten";
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-people me-2"></i>Benutzer verwalten</h1>
        <p class="mc-page-subtitle">@Model.Count() Benutzer insgesamt</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn-mc-ghost"><i class="bi bi-arrow-left"></i> Übersicht</a>
        <button class="btn-mc-primary" data-bs-toggle="modal" data-bs-target="#benutzerNeuModal">
            <i class="bi bi-person-plus"></i> Neuer Benutzer
        </button>
    </div>
</div>

<div class="mc-card">
    <div style="padding:0;">
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4 mb-0">Keine Benutzer.</p>
        }
        else
        {
            <div class="mc-table-wrapper">
                <table class="mc-table">
                    <thead>
                        <tr>
                            <th>Benutzername</th>
                            <th>Anzeigename</th>
                            <th>E-Mail</th>
                            <th>Rolle</th>
                            <th>Teams</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td><code>@b.Benutzername</code></td>
                                <td class="fw-semibold">@b.Anzeigename</td>
                                <td class="small">@b.EMail</td>
                                <td><span class="mc-badge badge-primary">@b.Rolle</span></td>
                                <td><span class="mc-badge badge-secondary">@b.AnzahlTeams</span></td>
                                <td>
                                    <span class="mc-badge @(b.IstAktiv ? "badge-success" : "badge-secondary")">
                                        @(b.IstAktiv ? "aktiv" : "deaktiviert")
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="BenutzerBearbeiten" asp-route-id="@b.Id" class="btn-mc-ghost" style="font-size:.78rem; padding:.3rem .7rem;">
                                        <i class="bi bi-pencil"></i> Bearbeiten
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Modal: Neuer Benutzer -->
<div class="modal fade" id="benutzerNeuModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="BenutzerAnlegen" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Neuer Benutzer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Benutzername (Login)</label>
                        <input name="Benutzername" class="form-control" required minlength="3" maxlength="80" autocomplete="off" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Anzeigename</label>
                        <input name="Anzeigename" class="form-control" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-Mail</label>
                        <input name="EMail" type="email" class="form-control" maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Initial-Passwort</label>
                        <input name="Passwort" type="text" class="form-control" required minlength="6" autocomplete="new-password" />
                        <div class="small text-muted">Der Benutzer sollte das Passwort nach erster Anmeldung ändern.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Rolle</label>
                        <select name="Rolle" class="form-select">
                            @foreach (Rolle r in Enum.GetValues<Rolle>())
                            {
                                <option value="@((int)r)">@r</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn-mc-primary"><i class="bi bi-check2 me-1"></i>Anlegen</button>
                </div>
            </form>
        </div>
    </div>
</div>
