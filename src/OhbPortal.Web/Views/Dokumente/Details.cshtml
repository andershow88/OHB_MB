    .ohb-richtext ul, .ohb-richtext ol { padding-left:1.2rem; }
    .ohb-richtext img { max-width:100%; height:auto; border-radius:6px; margin:.6rem 0; }
    .ohb-richtext table { border-collapse:collapse; margin:.8rem 0; }
    .ohb-richtext table th, .ohb-richtext table td { border:1px solid var(--mc-border); padding:.35rem .55rem; }
    .ohb-richtext .ql-align-center { text-align:center; }
    .ohb-richtext .ql-align-right { text-align:right; }
    .ohb-richtext .ql-align-justify { text-align:justify; }
</style>

@if (Model.Druckverbot)
{
    <style>
        .ohb-druckverbot { user-select: none; -webkit-user-select: none; }
        @@media print {
            body { visibility: hidden !important; }
            body::before {
                content: "Druckverbot – dieses Dokument darf nicht gedruckt werden.";
                visibility: visible;
                display: block;
                position: fixed;
                inset: 0;
                padding: 6rem 2rem;
                text-align: center;
                font-size: 1.6rem;
                font-weight: 700;
                color: #b00020;
                background: #fff;
                border: 4px solid #b00020;
                z-index: 99999;
            }
            body * { visibility: hidden !important; }
        }
    </style>
    <script>
        window.addEventListener('beforeprint', function () {
            alert('Dieses Dokument unterliegt einem Druckverbot. Bitte beachten Sie die Vorgaben der Richtlinie.');
        });
        document.addEventListener('DOMContentLoaded', function () {
            document.body.classList.add('ohb-druckverbot');
            var rt = document.querySelector('.ohb-richtext');
            if (rt) rt.addEventListener('contextmenu', e => e.preventDefault());
        });
    </script>
}

@functions {
    static string StatusBadgeClass(DokumentStatus s) => s switch
    {
        DokumentStatus.Entwurf => "badge-secondary",
        DokumentStatus.InFreigabe => "badge-warning",
        DokumentStatus.Freigegeben => "badge-success",
        DokumentStatus.Abgelehnt => "badge-danger",
        DokumentStatus.Archiviert => "badge-secondary",
        _ => "badge-secondary"
    };
    static string GesamtBadge(FreigabeEntscheidung s) => s switch
    {
        FreigabeEntscheidung.Zugestimmt => "badge-success",
        FreigabeEntscheidung.Abgelehnt => "badge-danger",
        _ => "badge-warning"
    };
}
