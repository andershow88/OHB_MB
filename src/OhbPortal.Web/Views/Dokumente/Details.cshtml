                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn-mc-primary w-100" style="font-size:.82rem; padding:.35rem .5rem;">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>
                            <div class="tab-pane fade" id="aclTabTeam">
                                <form asp-controller="Berechtigungen" asp-action="Hinzufuegen" method="post" class="row g-2 align-items-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="dokumentId" value="@Model.Id" />
                                    <input type="hidden" name="zielTyp" value="team" />
                                    <div class="col-md-6">
                                        <label class="form-label small mb-1">Team</label>
                                        <select name="teamId" class="form-select form-select-sm" required>
                                            <option value="">– wählen –</option>
                                            @foreach (var t in alleTeams)
                                            {
