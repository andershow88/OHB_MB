                                                <option value="@tid">@tn</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small mb-1">Typ</label>
                                        <select name="typ" class="form-select form-select-sm">
                                            @foreach (BerechtigungsTyp t in Enum.GetValues<BerechtigungsTyp>())
                                            {
                                                <option value="@((int)t)">@t</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn-mc-primary w-100" style="font-size:.82rem; padding:.35rem .5rem;">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>
                            <div class="tab-pane fade" id="aclTabRolle">
                                <form asp-controller="Berechtigungen" asp-action="Hinzufuegen" method="post" class="row g-2 align-items-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="dokumentId" value="@Model.Id" />
                                    <input type="hidden" name="zielTyp" value="rolle" />
                                    <div class="col-md-6">
                                        <label class="form-label small mb-1">Rolle</label>
                                        <select name="rolle" class="form-select form-select-sm" required>
                                            <option value="">– wählen –</option>
                                            @foreach (Rolle r in Enum.GetValues<Rolle>())
                                            {
                                                <option value="@((int)r)">@r</option>
                                            }
                                        </select>
