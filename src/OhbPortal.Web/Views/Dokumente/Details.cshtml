                                    <div class="col-md-4">
                                        <label class="form-label small mb-1">Typ</label>
                                        <select name="typ" class="form-select form-select-sm">
                                            @foreach (BerechtigungsTyp t in Enum.GetValues<BerechtigungsTyp>())
                                            {
                                                <option value="@((int)t)">@t</option>
                                            }
