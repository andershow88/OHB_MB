                    {
                        <span class="mc-badge badge-success"><i class="bi bi-globe2"></i> Öffentlich lesbar</span>
                    }
                    else
                    {
                        <span class="mc-badge badge-warning"><i class="bi bi-lock"></i> Eingeschränkt</span>
                    }
                    @if (Model.Druckverbot)
                    {
                        <span class="mc-badge badge-danger"><i class="bi bi-printer-dash"></i> Druckverbot</span>
