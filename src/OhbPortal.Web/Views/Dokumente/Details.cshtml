@model OhbPortal.Application.DTOs.DokumentDetailDto
@{
    ViewData["Title"] = Model.Titel;
    var versionen = ViewBag.Versionen as List<OhbPortal.Application.DTOs.VersionDto> ?? new();
    var audit = ViewBag.Audit as List<OhbPortal.Application.DTOs.AuditDto> ?? new();
    var freigaben = ViewBag.Freigaben as List<OhbPortal.Application.DTOs.FreigabeGruppeDto> ?? new();
    var kn = ViewBag.Kenntnisnahmen as List<OhbPortal.Application.DTOs.KenntnisnahmeDto> ?? new();
    var alleBenutzer = (ViewBag.AlleBenutzer as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var alleTeams = (ViewBag.AlleTeams as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    bool istEditor = User.IsInRole("Editor") || User.IsInRole("Admin") || User.IsInRole("Bereichsverantwortlicher");
    bool istApprover = User.IsInRole("Approver") || User.IsInRole("Admin");
    int meineBenutzerId = int.TryParse(User.FindFirst("BenutzerId")?.Value, out var bId) ? bId : 0;
    bool konfigAenderbar = Model.Status is DokumentStatus.Entwurf or DokumentStatus.Abgelehnt;
}

<div class="mc-page-header">
    <div>
        <div style="font-size:0.82rem; color:var(--mc-text-muted); margin-bottom:0.4rem;">
            <a asp-action="Index" style="color:var(--mc-primary);">Dokumente</a>
            <span style="margin:0 .4rem;">/</span>
            <span>@Model.KapitelPfad</span>
        </div>
        <h1 class="mc-page-title" style="font-size:1.25rem;">
            <i class="bi bi-file-earmark-text me-2"></i>@Model.Titel
            <span class="mc-badge @StatusBadgeClass(Model.Status) ms-2">@Model.Status</span>
            <span class="mc-badge badge-secondary ms-1">v@(Model.AktuelleVersion)</span>
            @if (Model.Archiviert) { <span class="mc-badge badge-secondary ms-1"><i class="bi bi-archive"></i> archiviert</span> }
            @if (Model.Geloescht) { <span class="mc-badge badge-danger ms-1"><i class="bi bi-trash"></i> Papierkorb</span> }
        </h1>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (!Model.Druckverbot && !Model.Geloescht)
        {
            <a asp-action="Drucken" asp-route-id="@Model.Id" target="_blank" rel="noopener"
               class="btn-mc-ghost" title="Druckvorschau (öffnet in neuem Tab)">
                <i class="bi bi-printer me-1"></i>Drucken
            </a>
        }
        @if (istEditor && !Model.Geloescht && !Model.Archiviert)
        {
            <a asp-action="Bearbeiten" asp-route-id="@Model.Id" class="btn-mc-primary">
                <i class="bi bi-pencil me-1"></i>Bearbeiten
            </a>
        }
        @if (istEditor && Model.Status == DokumentStatus.Entwurf && Model.FreigabeModus != FreigabeModus.Keine)
        {
            <form asp-action="FreigabeStarten" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button class="btn-mc-ghost" style="border-color:var(--mc-gold); color:var(--mc-gold);">
                    <i class="bi bi-play-circle me-1"></i>Freigabe starten
                </button>
            </form>
        }
        @if ((istApprover || User.IsInRole("Admin")) && !Model.Archiviert && Model.Status == DokumentStatus.Freigegeben)
        {
            <form asp-action="Archivieren" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button class="btn-mc-ghost"><i class="bi bi-archive me-1"></i>Archivieren</button>
            </form>
        }
        @if ((Model.Archiviert || Model.Geloescht) && (istApprover || User.IsInRole("Admin")))
        {
            <form asp-action="Wiederherstellen" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button class="btn-mc-ghost"><i class="bi bi-arrow-counterclockwise me-1"></i>Wiederherstellen</button>
            </form>
        }
        @if (istEditor && !Model.Geloescht)
        {
            <form asp-action="InPapierkorb" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Dokument in Papierkorb verschieben?');">
                @Html.AntiForgeryToken()
                <button class="btn-mc-ghost" style="color:var(--mc-danger);">
                    <i class="bi bi-trash me-1"></i>In Papierkorb
                </button>
            </form>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Hauptinhalt -->
    <div class="col-lg-8">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-text-paragraph"></i> Inhalt</h2>
            </div>
            <div class="mc-card-body" style="@(Model.Druckverbot ? "-webkit-user-select:none;user-select:none;" : "")">
                @if (!string.IsNullOrEmpty(Model.Kurzbeschreibung))
                {
                    <p class="text-muted" style="font-size:.9rem;">@Model.Kurzbeschreibung</p>
                }
                <div class="ohb-richtext">
                    @Html.Raw(Model.InhaltHtml ?? "<p class='text-muted'>Kein Inhalt erfasst.</p>")
                </div>
            </div>
        </div>

        @* ══ Freigabe-KONFIGURATION (Editor-Sicht) ═════════════════════════════ *@
        @if (istEditor && Model.FreigabeModus != FreigabeModus.Keine)
        {
            <div class="mc-card mt-4">
                <div class="mc-card-header">
                    <h2 class="mc-card-title"><i class="bi bi-sliders"></i> Freigabe-Konfiguration</h2>
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted">
                            Modus: @Model.FreigabeModus (@Model.FreigabeReihenfolge)
                        </span>
                        @if (konfigAenderbar)
                        {
                            <button class="btn-mc-primary" style="font-size:.78rem; padding:.3rem .65rem;"
                                    data-bs-toggle="modal" data-bs-target="#gruppeNeuModal">
                                <i class="bi bi-plus-circle"></i> Gruppe
                            </button>
                        }
                    </div>
                </div>
                <div class="mc-card-body">
                    @if (!konfigAenderbar)
                    {
                        <div class="alert alert-info py-2 mb-3 small">
                            <i class="bi bi-info-circle me-1"></i>
                            Konfiguration gesperrt — Dokument ist
                            @(Model.Status == DokumentStatus.InFreigabe ? "in Freigabe" :
                              Model.Status == DokumentStatus.Freigegeben ? "bereits freigegeben" : "archiviert").
                        </div>
                    }
                    @if (!freigaben.Any())
                    {
                        <p class="text-muted small mb-0">Noch keine Freigabegruppen angelegt.</p>
                    }
                    else
                    {
                        foreach (var g in freigaben)
                        {
                            <div style="border:1px solid var(--mc-border); border-radius:var(--mc-radius); padding:.85rem 1rem; margin-bottom:.6rem;">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    @if (Model.FreigabeReihenfolge == FreigabeReihenfolge.Sequentiell)
                                    {
                                        <span class="mc-badge badge-secondary" title="Stufe">Stufe @g.Reihenfolge</span>
                                    }
                                    <strong>@g.Bezeichnung</strong>
                                    <span class="small text-muted ms-auto">Quorum: @g.BenoetigteZustimmungen</span>
                                    @if (konfigAenderbar)
                                    {
                                        <button class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .45rem;"
                                                data-bs-toggle="modal" data-bs-target="#gruppeBearbeitenModal"
                                                onclick="gruppeVorbereiten(@g.Id, '@g.Bezeichnung.Replace("'", "\\'")', @g.Reihenfolge, @g.BenoetigteZustimmungen)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-controller="FreigabeGruppen" asp-action="Loeschen" method="post"
                                              style="display:inline;" onsubmit="return confirm('Freigabegruppe löschen?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="gruppeId" value="@g.Id" />
                                            <input type="hidden" name="dokumentId" value="@Model.Id" />
                                            <button class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .45rem; color:var(--mc-danger);">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                                <div class="small">
                                    <div class="fw-semibold mb-1" style="color:var(--mc-text-muted);">Mitglieder</div>
                                    @if (!g.Mitglieder.Any())
                                    {
                                        <em class="text-muted">Noch keine Mitglieder zugewiesen.</em>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var m in g.Mitglieder)
                                            {
                                                <span class="mc-badge badge-primary d-inline-flex align-items-center" style="gap:.4rem; font-size:.72rem;">
                                                    <i class="bi bi-person"></i> @m.Anzeigename
                                                    @if (konfigAenderbar)
                                                    {
                                                        <form asp-controller="FreigabeGruppen" asp-action="MitgliedEntfernen" method="post" style="display:inline;">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="mitgliedId" value="@m.MitgliedId" />
                                                            <input type="hidden" name="dokumentId" value="@Model.Id" />
                                                            <button class="btn-link p-0 border-0" style="background:none; color:inherit; line-height:1;">
                                                                <i class="bi bi-x-circle"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                </span>
                                            }
                                        </div>
                                    }
                                    @if (konfigAenderbar)
                                    {
                                        <form asp-controller="FreigabeGruppen" asp-action="MitgliedHinzufuegen" method="post"
                                              class="d-flex gap-2 mt-2 align-items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="gruppeId" value="@g.Id" />
                                            <input type="hidden" name="dokumentId" value="@Model.Id" />
                                            <select name="benutzerId" class="form-select form-select-sm" required style="max-width:260px;">
                                                <option value="">– Benutzer hinzufügen –</option>
                                                @foreach (var b in alleBenutzer)
                                                {
                                                    int bId2 = (int)b.Id;
                                                    string ba = (string)b.Anzeigename;
                                                    if (!g.Mitglieder.Any(m => m.BenutzerId == bId2))
                                                    {
                                                        <option value="@bId2">@ba</option>
                                                    }
                                                }
                                            </select>
                                            <button class="btn-mc-ghost" style="font-size:.72rem; padding:.25rem .55rem;">
                                                <i class="bi bi-person-plus"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        @* ══ Freigaben-STATUS / Entscheidungen (Approver-Sicht) ════════════════ *@
        <div class="mc-card mt-4">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-check2-square"></i> Freigaben</h2>
                <span class="small text-muted">
                    @if (Model.FreigabeModus == FreigabeModus.Keine)
                    { <span>Kein Workflow</span> }
                    else
                    { <span>Modus: @Model.FreigabeModus (@Model.FreigabeReihenfolge)</span> }
                </span>
            </div>
            <div class="mc-card-body">
                @if (Model.FreigabeModus == FreigabeModus.Keine)
                {
                    <p class="text-muted small mb-0">
                        Kein Freigabe-Workflow aktiv. Ändern Sie den Modus im
                        <a asp-action="Bearbeiten" asp-route-id="@Model.Id">Dokument-Edit</a>.
                    </p>
                }
                else if (!freigaben.Any())
                {
                    <p class="text-muted small mb-0">Keine Freigabegruppen konfiguriert. Siehe oben „Freigabe-Konfiguration".</p>
                }
                else
                {
                    @foreach (var g in freigaben)
                    {
                        <div style="border:1px solid var(--mc-border); border-radius:var(--mc-radius); padding:.85rem 1rem; margin-bottom:.6rem;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                @if (Model.FreigabeReihenfolge == FreigabeReihenfolge.Sequentiell)
                                {
                                    <span class="mc-badge badge-secondary">Stufe @g.Reihenfolge</span>
                                }
                                <strong>@g.Bezeichnung</strong>
                                <span class="mc-badge @GesamtBadge(g.Gesamtstatus)">@g.Gesamtstatus</span>
                                <span class="small text-muted ms-auto">
                                    @g.Zustimmungen.Count(z => z.Entscheidung == FreigabeEntscheidung.Zugestimmt)
                                    / @g.BenoetigteZustimmungen Zustimmungen
                                </span>
                            </div>
                            @if (g.Zustimmungen.Any())
                            {
                                @foreach (var z in g.Zustimmungen)
                                {
                                    <div class="small" style="padding:.2rem 0; border-top:1px dashed var(--mc-border);">
                                        <span class="mc-badge @GesamtBadge(z.Entscheidung)">@z.Entscheidung</span>
                                        <strong>@z.Benutzer</strong>
                                        @if (z.EntschiedenAm.HasValue) { <span class="text-muted">· @z.EntschiedenAm.Value.ToString("dd.MM.yyyy HH:mm")</span> }
                                        @if (!string.IsNullOrEmpty(z.Kommentar)) { <div class="text-muted ms-4">„@z.Kommentar"</div> }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="small text-muted">Noch keine Entscheidungen erfasst.</div>
                            }
                            @if (Model.Status == DokumentStatus.InFreigabe && g.Mitglieder.Any(m => m.BenutzerId == meineBenutzerId))
                            {
                                <form asp-action="FreigabeZustimmen" method="post" class="mt-2 d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="dokumentId" value="@Model.Id" />
                                    <input type="hidden" name="freigabeGruppeId" value="@g.Id" />
                                    <input type="text" name="kommentar" class="form-control form-control-sm" placeholder="Kommentar (optional)" />
                                    <button type="submit" class="btn-mc-ghost" style="border-color:var(--mc-success); color:var(--mc-success);">
                                        <i class="bi bi-check2"></i> Zustimmen
                                    </button>
                                    <button type="submit" formaction="@Url.Action("FreigabeAblehnen")" class="btn-mc-ghost" style="color:var(--mc-danger);">
                                        <i class="bi bi-x-lg"></i> Ablehnen
                                    </button>
                                </form>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        @if (istEditor && konfigAenderbar && Model.FreigabeModus != FreigabeModus.Keine)
        {
            <!-- Modal: neue Gruppe -->
            <div class="modal fade" id="gruppeNeuModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="FreigabeGruppen" asp-action="Anlegen" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="dokumentId" value="@Model.Id" />
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-check2-square me-2"></i>Neue Freigabegruppe</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Bezeichnung</label>
                                    <input name="bezeichnung" class="form-control" placeholder="z.B. Informationssicherheit" required />
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label fw-semibold small">Stufe / Reihenfolge</label>
                                        <input name="reihenfolge" type="number" min="1" value="1" class="form-control form-control-sm" />
                                        <div class="small text-muted">Bei sequentiellen Workflows wichtig.</div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-semibold small">Benötigte Zustimmungen (Quorum)</label>
                                        <input name="benoetigteZustimmungen" type="number" min="1" value="1" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                                <button type="submit" class="btn-mc-primary"><i class="bi bi-check2 me-1"></i>Anlegen</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal: Gruppe bearbeiten -->
            <div class="modal fade" id="gruppeBearbeitenModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="FreigabeGruppen" asp-action="Bearbeiten" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="dokumentId" value="@Model.Id" />
                            <input type="hidden" name="gruppeId" id="gb_gruppeId" />
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Freigabegruppe bearbeiten</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Bezeichnung</label>
                                    <input name="bezeichnung" id="gb_bezeichnung" class="form-control" required />
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label fw-semibold small">Stufe</label>
                                        <input name="reihenfolge" id="gb_reihenfolge" type="number" min="1" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-semibold small">Quorum</label>
                                        <input name="benoetigteZustimmungen" id="gb_quorum" type="number" min="1" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                                <button type="submit" class="btn-mc-primary"><i class="bi bi-check2 me-1"></i>Speichern</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- Kenntnisnahmen -->
        <div class="mc-card mt-4">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-eye"></i> Kenntnisnahmen</h2>
                <span class="small text-muted">@kn.Count(k => k.Status == KenntnisnahmeStatus.Bestaetigt) / @kn.Count bestätigt</span>
            </div>
            <div class="mc-card-body">
                @if (istEditor)
                {
                    <div style="background:var(--mc-bg); border:1px solid var(--mc-border); border-radius:var(--mc-radius); padding:.85rem 1rem; margin-bottom:1rem;">
                        <div class="fw-semibold small mb-2" style="color:var(--mc-text-muted);">
                            <i class="bi bi-person-plus me-1"></i>Neue Kenntnisnahme zuweisen
                        </div>

                        <ul class="nav nav-tabs mb-2" role="tablist" style="font-size:.85rem;">
                            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#knTabUser" type="button">Benutzer</button></li>
                            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#knTabTeam" type="button">Team</button></li>
                        </ul>
                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="knTabUser">
                                <form asp-controller="Kenntnisnahmen" asp-action="ZuweisenBenutzer" method="post" class="row g-2 align-items-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="dokumentId" value="@Model.Id" />
                                    <div class="col-md-6">
                                        <label class="form-label small mb-1">Benutzer</label>
                                        <select name="benutzerId" class="form-select form-select-sm" required>
                                            <option value="">– Benutzer wählen –</option>
                                            @foreach (var b in alleBenutzer)
                                            {
                                                int bId2 = (int)b.Id;
                                                string ba = (string)b.Anzeigename;
                                                if (!kn.Any(x => x.Ziel == $"Benutzer: {ba}"))
                                                {
                                                    <option value="@bId2">@ba</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small mb-1">Fällig bis (optional)</label>
                                        <input name="faelligkeit" type="date" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn-mc-primary w-100" style="font-size:.82rem; padding:.35rem .5rem;">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>
                            <div class="tab-pane fade" id="knTabTeam">
                                <form asp-controller="Kenntnisnahmen" asp-action="ZuweisenTeam" method="post" class="row g-2 align-items-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="dokumentId" value="@Model.Id" />
                                    <div class="col-md-6">
                                        <label class="form-label small mb-1">Team</label>
                                        <select name="teamId" class="form-select form-select-sm" required>
                                            <option value="">– Team wählen –</option>
                                            @foreach (var t in alleTeams)
                                            {
                                                int tId = (int)t.Id;
                                                string tn = (string)t.Name;
                                                if (!kn.Any(x => x.Ziel == $"Team: {tn}"))
                                                {
                                                    <option value="@tId">@tn</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small mb-1">Fällig bis (optional)</label>
                                        <input name="faelligkeit" type="date" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn-mc-primary w-100" style="font-size:.82rem; padding:.35rem .5rem;">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }

                @if (!kn.Any())
                {
                    <p class="text-muted small mb-0">Keine Kenntnisnahmen zugewiesen.</p>
                }
                else
                {
                    <table class="table table-sm mb-0" style="font-size:.85rem;">
                        <thead>
                            <tr>
                                <th>Ziel</th>
                                <th>Status</th>
                                <th>Fällig</th>
                                <th>Bestätigt</th>
                                @if (istEditor) { <th style="width:40px;"></th> }
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var k in kn)
                        {
                            var ueberfaellig = k.Faelligkeit.HasValue && k.Faelligkeit.Value < DateTime.UtcNow && k.Status != KenntnisnahmeStatus.Bestaetigt;
                            <tr>
                                <td>@k.Ziel</td>
                                <td>
                                    <span class="mc-badge @(k.Status == KenntnisnahmeStatus.Bestaetigt ? "badge-success" : ueberfaellig ? "badge-danger" : "badge-warning")">
                                        @(ueberfaellig ? "überfällig" : k.Status.ToString())
                                    </span>
                                </td>
                                <td class="@(ueberfaellig ? "text-danger fw-semibold" : "")">@(k.Faelligkeit?.ToString("dd.MM.yyyy") ?? "–")</td>
                                <td>
                                    @if (k.BestaetigtAm.HasValue) { <span>@k.BestaetigtAm.Value.ToString("dd.MM.yyyy") – @k.BestaetigtVon</span> }
                                    else { <span class="text-muted">–</span> }
                                </td>
                                @if (istEditor)
                                {
                                    <td>
                                        <form asp-controller="Kenntnisnahmen" asp-action="Loeschen" method="post"
                                              onsubmit="return confirm('Kenntnisnahme entfernen?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="kenntnisnahmeId" value="@k.Id" />
                                            <input type="hidden" name="dokumentId" value="@Model.Id" />
                                            <button class="btn-link p-0 border-0" style="background:none; color:var(--mc-danger); line-height:1;" title="Entfernen">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @* ══ Berechtigungen (ACL) ══════════════════════════════════════════════ *@
        @{
            var berechtigungen = ViewBag.Berechtigungen as List<OhbPortal.Application.DTOs.BerechtigungDto> ?? new();
        }
