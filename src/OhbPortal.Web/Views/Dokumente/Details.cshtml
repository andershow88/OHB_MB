        <!-- Versionen + Audit-Timeline -->
        <div class="row g-3 mt-1">
            <div class="col-md-6">
                <div class="mc-card">
                    <div class="mc-card-header">
                        <h2 class="mc-card-title"><i class="bi bi-layers"></i> Versionen</h2>
                    </div>
                    <div class="mc-card-body" style="padding:0;">
                        <ul class="list-unstyled mb-0">
                        @foreach (var v in versionen)
                        {
                            <li style="padding:.6rem 1rem; border-bottom:1px solid var(--mc-border);">
                                <div class="d-flex align-items-center gap-2">
                                    <code>v@(v.Versionsnummer)</code>
                                    <span class="mc-badge @StatusBadgeClass(v.StatusZumZeitpunkt)" style="font-size:.65rem;">@v.StatusZumZeitpunkt</span>
                                    <span class="ms-auto small text-muted">@v.ErstelltAm.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                                <div class="small">@v.ErstelltVon</div>
                                @if (!string.IsNullOrEmpty(v.AenderungsHinweis)) { <div class="small text-muted">„@v.AenderungsHinweis"</div> }
                            </li>
                        }
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mc-card">
                    <div class="mc-card-header">
                        <h2 class="mc-card-title"><i class="bi bi-clock-history"></i> Änderungsverlauf</h2>
                    </div>
                    <div class="mc-card-body" style="padding:0; max-height:400px; overflow-y:auto;">
                        <ul class="list-unstyled mb-0">
                        @foreach (var a in audit)
                        {
                            <li style="padding:.5rem 1rem; border-bottom:1px solid var(--mc-border); font-size:.82rem;">
                                <div class="d-flex gap-2">
                                    <i class="bi bi-circle-fill" style="color:var(--mc-gold); font-size:.5rem; margin-top:.4rem;"></i>
                                    <div style="flex:1;">
                                        <strong>@a.Typ</strong>
                                        <span class="ms-2 text-muted">@a.Zeitpunkt.ToString("dd.MM.yyyy HH:mm")</span>
                                        <div class="small text-muted">@a.Benutzer @(string.IsNullOrEmpty(a.Beschreibung) ? "" : " · " + a.Beschreibung)</div>
                                    </div>
                                </div>
                            </li>
                        }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Seitenleiste: Metadaten + Anhänge -->
    <div class="col-lg-4">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-info-circle"></i> Metadaten</h2>
            </div>
            <div class="mc-card-body">
                <dl class="row mb-0" style="font-size:.85rem;">
                    <dt class="col-5 text-muted">Kapitel</dt><dd class="col-7">@Model.KapitelPfad</dd>
                    <dt class="col-5 text-muted">Verantwortlich</dt><dd class="col-7">@(Model.VerantwortlicherBereich ?? "–")</dd>
                    <dt class="col-5 text-muted">Kategorie</dt><dd class="col-7">@(Model.Kategorie ?? "–")</dd>
                    <dt class="col-5 text-muted">Schlagworte</dt><dd class="col-7">@(Model.Tags ?? "–")</dd>
                    <dt class="col-5 text-muted">Sichtbar ab</dt><dd class="col-7">@(Model.SichtbarAb?.ToString("dd.MM.yyyy") ?? "–")</dd>
                    <dt class="col-5 text-muted">Sichtbar bis</dt><dd class="col-7">@(Model.SichtbarBis?.ToString("dd.MM.yyyy") ?? "–")</dd>
                    <dt class="col-5 text-muted">Prüftermin</dt>
                    <dd class="col-7" style="position:relative;">
                        <span id="prueftermAnzeige" @(istEditor ? "style=cursor:pointer;border-bottom:1px dashed var(--mc-primary);padding-bottom:1px;" : "")
                              @(istEditor ? "onclick=prueftermPopupOeffnen() title=Klicken zum Ändern" : "")>
                            @if (Model.Pruefterm.HasValue)
                            {
                                var ueb = Model.Pruefterm.Value < DateTime.UtcNow;
                                <span class="@(ueb ? "text-danger fw-semibold" : "")">@Model.Pruefterm.Value.ToString("dd.MM.yyyy")</span>
                                if (ueb) { <span class="mc-badge badge-danger ms-1">überfällig</span> }
                            }
                            else { <span>–</span> }
                            @if (istEditor) { <i class="bi bi-pencil-square ms-1" style="font-size:.75rem; color:var(--mc-primary); opacity:.6;"></i> }
                        </span>

                        @if (istEditor)
                        {
                            <div id="prueftermPopup" style="display:none; position:absolute; top:100%; left:0; z-index:50; background:var(--mc-bg-card, #fff); border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); box-shadow:var(--mc-shadow-lg); padding:1rem; width:280px; margin-top:.25rem;">
                                <div style="font-weight:600; font-size:.85rem; margin-bottom:.75rem; color:var(--mc-text-dark, #333);">
                                    <i class="bi bi-calendar-event" style="color:var(--mc-primary);"></i> Prüftermin ändern
                                </div>
                                <label style="font-size:.78rem; color:var(--mc-text-muted); display:block; margin-bottom:.25rem;">Neuer Prüftermin</label>
                                <input type="date" id="prueftermNeu" class="form-control form-control-sm" style="margin-bottom:.65rem;"
                                       value="@(Model.Pruefterm?.ToString("yyyy-MM-dd"))" />
                                <label style="font-size:.78rem; color:var(--mc-text-muted); display:block; margin-bottom:.25rem;">Kommentar (optional)</label>
                                <input type="text" id="prueftermKommentar" class="form-control form-control-sm" placeholder="z.B. Verlängerung um 6 Monate" style="margin-bottom:.75rem;" />
                                <div style="display:flex; gap:.5rem;">
                                    <button onclick="prueftermSpeichern()" class="btn-mc-primary" style="flex:1; font-size:.8rem; padding:.35rem .75rem;">
                                        <i class="bi bi-check-lg"></i> Speichern
                                    </button>
                                    <button onclick="prueftermPopupSchliessen()" class="btn-mc-outline" style="font-size:.8rem; padding:.35rem .75rem;">
                                        Abbrechen
                                    </button>
                                </div>
                                <div id="prueftermFehler" style="font-size:.78rem; color:var(--mc-danger, #c44); margin-top:.5rem; display:none;"></div>
                            </div>
                        }
                    </dd>
                    <dt class="col-5 text-muted">Erstellt</dt><dd class="col-7">@Model.ErstelltAm.ToString("dd.MM.yyyy") · @Model.ErstelltVon</dd>
                    <dt class="col-5 text-muted">Geändert</dt><dd class="col-7">@Model.GeaendertAm.ToString("dd.MM.yyyy HH:mm") · @Model.GeaendertVon</dd>
                </dl>
                <hr style="border-color:var(--mc-border);" />
                <div class="small">
                    @if (Model.Druckverbot) { <div><i class="bi bi-printer-dash me-1 text-danger"></i> Druckverbot</div> }
                    @if (!Model.OeffentlichLesbar) { <div><i class="bi bi-lock me-1"></i> Eingeschränkte Sichtbarkeit</div> }
                    @if (Model.Druckverbot == false && Model.OeffentlichLesbar) { <div class="text-muted"><i class="bi bi-globe2 me-1"></i> Öffentlich lesbar, Druck erlaubt</div> }
                </div>
            </div>
        </div>

        <!-- Anhänge -->
        <div class="mc-card mt-3">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-paperclip"></i> Anhänge (@Model.Anhaenge.Count)</h2>
            </div>
            <div class="mc-card-body">
                @if (istEditor)
                {
                    <form asp-action="AnhangHochladen" method="post" enctype="multipart/form-data" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="dokumentId" value="@Model.Id" />
                        <div class="input-group input-group-sm">
                            <input type="file" name="datei" class="form-control form-control-sm" required />
                            <button class="btn-mc-primary" style="font-size:.78rem; padding:.2rem .5rem;">
                                <i class="bi bi-upload"></i>
                            </button>
                        </div>
                    </form>
                }
                @if (!Model.Anhaenge.Any())
                {
                    <p class="text-muted small mb-0">Keine Anhänge.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                    @foreach (var a in Model.Anhaenge)
                    {
                        <li style="padding:.45rem 0; border-bottom:1px solid var(--mc-border); font-size:.82rem;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-file-earmark" style="color:var(--mc-text-muted);"></i>
                                <div style="flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis;">@a.Dateiname</div>
                                <a asp-action="AnhangHerunterladen" asp-route-anhangId="@a.Id" class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .45rem;">
                                    <i class="bi bi-download"></i>
                                </a>
                                @if (istEditor)
                                {
                                    <form asp-action="AnhangLoeschen" method="post" style="display:inline;"
                                          onsubmit="return confirm('Anhang löschen?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="anhangId" value="@a.Id" />
                                        <input type="hidden" name="dokumentId" value="@Model.Id" />
                                        <button type="submit" class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .45rem; color:var(--mc-danger);">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                            <div class="small text-muted">
                                @(a.Bytes / 1024) KB · @a.HochgeladenVon · @a.HochgeladenAm.ToString("dd.MM.yyyy")
                            </div>
                        </li>
                    }
                    </ul>
                }
            </div>
        </div>

        @if (Model.Verlinkungen.Any())
        {
            <div class="mc-card mt-3">
                <div class="mc-card-header">
                    <h2 class="mc-card-title"><i class="bi bi-link-45deg"></i> Verlinkte Dokumente</h2>
                </div>
                <div class="mc-card-body">
                    <ul class="list-unstyled mb-0">
                        @foreach (var l in Model.Verlinkungen)
                        {
                            <li><a asp-action="Details" asp-route-id="@l.ZielDokumentId">@(l.Bezeichnung ?? l.ZielTitel)</a></li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    // ── Prüftermin Inline-Edit ──
    function prueftermPopupOeffnen() {
        document.getElementById('prueftermPopup').style.display = 'block';
        document.getElementById('prueftermFehler').style.display = 'none';
    }
    function prueftermPopupSchliessen() {
        document.getElementById('prueftermPopup').style.display = 'none';
    }
    document.addEventListener('click', function(e) {
        var popup = document.getElementById('prueftermPopup');
        var anzeige = document.getElementById('prueftermAnzeige');
        if (popup && popup.style.display === 'block' && !popup.contains(e.target) && !anzeige.contains(e.target)) {
            popup.style.display = 'none';
        }
    });
    async function prueftermSpeichern() {
        var datum = document.getElementById('prueftermNeu').value;
        var kommentar = document.getElementById('prueftermKommentar').value;
        var fehlerEl = document.getElementById('prueftermFehler');
        try {
            var r = await fetch('/Dokumente/PrueftermAendern/@Model.Id', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    neuerPruefterm: datum || null,
                    kommentar: kommentar || null
                })
            });
            var data = await r.json();
            if (data.ok) {
                location.reload();
            } else {
                fehlerEl.textContent = data.error || 'Fehler beim Speichern';
                fehlerEl.style.display = 'block';
            }
        } catch {
            fehlerEl.textContent = 'Verbindungsfehler';
            fehlerEl.style.display = 'block';
        }
    }

    function gruppeVorbereiten(id, bez, reihenfolge, quorum) {
        document.getElementById('gb_gruppeId').value = id;
        document.getElementById('gb_bezeichnung').value = bez;
        document.getElementById('gb_reihenfolge').value = reihenfolge;
        document.getElementById('gb_quorum').value = quorum;
    }
</script>
}

