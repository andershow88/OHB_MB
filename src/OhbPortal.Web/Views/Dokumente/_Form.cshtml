@model OhbPortal.Web.ViewModels.DokumentBearbeitenViewModel
@Html.AntiForgeryToken()

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
<style>
    .ql-toolbar.ql-snow, .ql-container.ql-snow { border-color: var(--mc-border); }
    .ql-editor { min-height: 440px; font-size: .95rem; line-height: 1.6; color: var(--mc-text); background: var(--mc-bg-card); }
    .ql-editor h1 { font-size: 1.45rem; margin-top: 1.4rem; }
    .ql-editor h2 { font-size: 1.15rem; margin-top: 1.2rem; }
    .ql-editor h3 { font-size: 1rem; margin-top: 1rem; }
    .ql-editor h4 { font-size: .92rem; margin-top: .9rem; }
    .ql-editor img { max-width: 100%; height: auto; border-radius: 6px; margin: .5rem 0; }
    .ql-editor blockquote { border-left: 3px solid var(--mc-gold); background: var(--mc-bg); padding: .6rem .95rem; border-radius: 6px; }
    .ql-editor code { background: rgba(0,0,0,.06); padding: .1em .35em; border-radius: 4px; font-size: .88em; }
    .ql-toolbar .ql-stroke { stroke: var(--mc-text); }
    .ql-toolbar .ql-fill { fill: var(--mc-text); }
    .ql-toolbar .ql-picker-label, .ql-toolbar .ql-picker-item { color: var(--mc-text); }
    [data-theme="dark"] .ql-toolbar.ql-snow { background: var(--mc-bg); }
    [data-theme="dark"] .ql-container.ql-snow { background: var(--mc-bg-card); }
    [data-theme="dark"] .ql-picker-options { background: var(--mc-bg-card); border-color: var(--mc-border); }
    [data-theme="dark"] .ql-tooltip { background: var(--mc-bg-card) !important; color: var(--mc-text) !important; border-color: var(--mc-border) !important; }
    [data-theme="dark"] .ql-tooltip input { background: var(--mc-bg); color: var(--mc-text); border-color: var(--mc-border); }
</style>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="mc-card">
            <div class="mc-card-body">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Titel" class="form-label fw-semibold"></label>
                    <input asp-for="Titel" class="form-control" placeholder="Aussagekräftiger Titel" />
                    <span asp-validation-for="Titel" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Kurzbeschreibung" class="form-label fw-semibold"></label>
                    <input asp-for="Kurzbeschreibung" class="form-control" placeholder="Einzeiler – erscheint in Listen" />
                </div>
                <div class="mb-3">
                    <label asp-for="InhaltHtml" class="form-label fw-semibold"></label>
                    <input type="hidden" asp-for="InhaltHtml" id="InhaltHtmlHidden" />
                    <div id="ohb-editor"></div>
                    <div class="small text-muted mt-1">
                        <i class="bi bi-info-circle me-1"></i>
                        Überschriften für Struktur nutzen · Bilder per <i class="bi bi-image"></i> einfügen (bis 10 MB) · Ctrl/Cmd+B für Fett · Ctrl/Cmd+I für Kursiv
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-info-circle"></i> Zuordnung</h2>
            </div>
            <div class="mc-card-body">
                <div class="mb-3">
                    <label asp-for="KapitelId" class="form-label fw-semibold"></label>
                    <select asp-for="KapitelId" asp-items="(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Kapitel" class="form-select">
                        <option value="">– Bitte wählen –</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="VerantwortlicherBereichId" class="form-label fw-semibold"></label>
                    <select asp-for="VerantwortlicherBereichId" asp-items="(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Teams" class="form-select">
                        <option value="">– optional –</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="Kategorie" class="form-label fw-semibold"></label>
                    <input asp-for="Kategorie" class="form-control" placeholder="z.B. Richtlinie, Anweisung, Formular" />
                </div>
                <div class="mb-3">
                    <label asp-for="Tags" class="form-label fw-semibold"></label>
                    <input asp-for="Tags" class="form-control" placeholder="fernwartung, it, sicherheit" />
                </div>
            </div>
        </div>

        <div class="mc-card mt-3">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-calendar-check"></i> Termine</h2>
            </div>
            <div class="mc-card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <label asp-for="SichtbarAb" class="form-label fw-semibold small"></label>
                        <input asp-for="SichtbarAb" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label asp-for="SichtbarBis" class="form-label fw-semibold small"></label>
                        <input asp-for="SichtbarBis" class="form-control form-control-sm" />
                    </div>
                    <div class="col-12 mt-2">
                        <label asp-for="Pruefterm" class="form-label fw-semibold small"></label>
                        <input asp-for="Pruefterm" class="form-control form-control-sm" />
                    </div>
                </div>
            </div>
        </div>

        <div class="mc-card mt-3">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-check2-square"></i> Freigabe-Workflow</h2>
            </div>
            <div class="mc-card-body">
                <div class="mb-2">
                    <label asp-for="FreigabeModus" class="form-label fw-semibold small"></label>
                    <select asp-for="FreigabeModus" class="form-select form-select-sm">
                        @foreach (FreigabeModus m in Enum.GetValues<FreigabeModus>())
                        {
                            if (Model.FreigabeModus == m) { <option value="@((int)m)" selected>@m</option> }
                            else { <option value="@((int)m)">@m</option> }
                        }
                    </select>
                </div>
                <div class="mb-2">
                    <label asp-for="FreigabeReihenfolge" class="form-label fw-semibold small"></label>
                    <select asp-for="FreigabeReihenfolge" class="form-select form-select-sm">
                        @foreach (FreigabeReihenfolge r in Enum.GetValues<FreigabeReihenfolge>())
                        {
                            if (Model.FreigabeReihenfolge == r) { <option value="@((int)r)" selected>@r</option> }
                            else { <option value="@((int)r)">@r</option> }
                        }
                    </select>
                </div>
                <div class="small text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    Gruppen und Mitglieder werden nach dem Speichern im Dokument-Details unter „Freigabe-Konfiguration" gepflegt.
                </div>
            </div>
        </div>

        <div class="mc-card mt-3">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-shield-lock"></i> Sicherheit</h2>
            </div>
            <div class="mc-card-body">
                <div class="form-check mb-2">
                    <input asp-for="OeffentlichLesbar" class="form-check-input" />
                    <label asp-for="OeffentlichLesbar" class="form-check-label small"></label>
                </div>
                <div class="form-check">
                    <input asp-for="Druckverbot" class="form-check-input" />
                    <label asp-for="Druckverbot" class="form-check-label small"></label>
                </div>
            </div>
        </div>

        <div class="mc-card mt-3">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-link-45deg"></i> Mitgeltende Dokumente</h2>
            </div>
            <div class="mc-card-body">
                <div style="position:relative;">
                    <input id="verlinkungSuche" type="text" class="form-control form-control-sm"
                           placeholder="Dokument-Titel suchen (ab 2 Zeichen) …" autocomplete="off" />
                    <div id="verlinkungDropdown"
                         style="display:none; position:absolute; top:calc(100% + 2px); left:0; right:0; z-index:40;
                                background:var(--mc-bg-card); border:1px solid var(--mc-border);
                                border-radius:var(--mc-radius-sm); box-shadow:var(--mc-shadow); max-height:280px; overflow-y:auto;"></div>
                </div>
                <div id="verlinkungChips" class="mt-2 d-flex flex-wrap gap-1"></div>
                <div class="small text-muted mt-2">
                    <i class="bi bi-info-circle me-1"></i>
                    Ausgewählte Dokumente erscheinen als Verweise in der Detail-Ansicht.
                </div>
            </div>
        </div>

        @if (Model.Id.HasValue)
        {
            <div class="mc-card mt-3">
                <div class="mc-card-body">
                    <label asp-for="AenderungsHinweis" class="form-label fw-semibold small">Änderungshinweis (Version)</label>
                    <textarea asp-for="AenderungsHinweis" class="form-control form-control-sm" rows="2" placeholder="Was wurde geändert?"></textarea>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn-mc-primary">
        <i class="bi bi-check2 me-1"></i>Speichern
    </button>
    <a asp-action="Index" class="btn-mc-ghost">Abbrechen</a>
</div>

<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script>
    (function () {
        const dokumentId = @(Model.Id?.ToString() ?? "null");
        const hidden = document.getElementById('InhaltHtmlHidden');
        const initial = hidden.value || '';

        const toolbarOptions = [
            [{ header: [1, 2, 3, 4, false] }],
            [{ font: [] }],
            [{ size: ['small', false, 'large', 'huge'] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ color: [] }, { background: [] }],
            [{ align: [] }],
            [{ list: 'ordered' }, { list: 'bullet' }, { list: 'check' }],
            [{ indent: '-1' }, { indent: '+1' }],
            ['blockquote', 'code-block'],
            ['link', 'image', 'video'],
            ['clean']
        ];

        const quill = new Quill('#ohb-editor', {
            theme: 'snow',
            placeholder: 'Inhalt hier erfassen …',
            modules: {
                toolbar: {
                    container: toolbarOptions,
                    handlers: {
                        image: bildEinfuegen
                    }
                }
            }
        });

        if (initial) quill.clipboard.dangerouslyPasteHTML(initial);

        function antiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        async function bildEinfuegen() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.click();
            input.onchange = async () => {
                const file = input.files && input.files[0];
                if (!file) return;
                if (file.size > 10 * 1024 * 1024) {
                    alert('Bild zu groß (max. 10 MB).');
                    return;
                }
                const fd = new FormData();
                fd.append('datei', file);
                if (dokumentId) fd.append('dokumentId', dokumentId);
                fd.append('__RequestVerificationToken', antiForgeryToken());

                try {
                    const resp = await fetch('/Dokumente/BildHochladen', { method: 'POST', body: fd });
                    const data = await resp.json();
                    if (data.error) { alert(data.error); return; }
                    if (data.url) {
                        const range = quill.getSelection(true);
                        quill.insertEmbed(range.index, 'image', data.url, 'user');
                        quill.setSelection(range.index + 1, 0);
                    }
                } catch (ex) {
                    alert('Fehler beim Upload: ' + ex.message);
                }
            };
        }

        const form = hidden.closest('form');
        if (form) {
            form.addEventListener('submit', () => {
                hidden.value = quill.root.innerHTML;
            });
        }

        // ── Mitgeltende Dokumente: Autocomplete + Chips ─────────────────
        const existing = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                (ViewBag.BestehendeVerlinkungen as System.Collections.IEnumerable)?
                    .Cast<dynamic>()
                    .Select(v => new { id = (int)v.ZielDokumentId, titel = (string)v.ZielTitel })
                ?? Enumerable.Empty<object>()));

        const verlinkungen = new Map();
        existing.forEach(v => verlinkungen.set(v.id, v.titel));

        const sucheInput = document.getElementById('verlinkungSuche');
        const dropdown = document.getElementById('verlinkungDropdown');
        const chipsContainer = document.getElementById('verlinkungChips');

        function renderChips() {
            chipsContainer.innerHTML = '';
            verlinkungen.forEach((titel, id) => {
                const chip = document.createElement('span');
                chip.className = 'mc-badge badge-primary d-inline-flex align-items-center';
                chip.style.cssText = 'gap:.4rem; font-size:.72rem;';
                chip.innerHTML = `
                    <input type="hidden" name="VerlinkteDokumentIds" value="${id}" />
                    <i class="bi bi-link-45deg"></i>
                    <span>${titel.replace(/</g,'&lt;')}</span>
                    <button type="button" class="btn-link p-0 border-0"
                            style="background:none; color:inherit; line-height:1;"
                            onclick="window.verlinkungEntfernen(${id})">
                        <i class="bi bi-x-circle"></i>
                    </button>`;
                chipsContainer.appendChild(chip);
            });
        }
        window.verlinkungEntfernen = function(id) {
            verlinkungen.delete(id);
            renderChips();
        };
        renderChips();

        let debounceTimer = null;
        sucheInput.addEventListener('input', () => {
            const q = sucheInput.value.trim();
            clearTimeout(debounceTimer);
            if (q.length < 2) { dropdown.style.display = 'none'; return; }
            debounceTimer = setTimeout(async () => {
                const excl = dokumentId != null ? `&excludeId=${dokumentId}` : '';
                const resp = await fetch(`/Dokumente/Vorschlaege?q=${encodeURIComponent(q)}${excl}`);
                const data = await resp.json();
                if (!Array.isArray(data) || data.length === 0) {
                    dropdown.style.display = 'none';
                    return;
                }
                dropdown.innerHTML = data
                    .filter(d => !verlinkungen.has(d.id))
                    .map(d => `
                        <div class="verlinkung-vorschlag"
                             data-id="${d.id}" data-titel="${d.titel.replace(/"/g,'&quot;')}"
                             style="padding:.5rem .75rem; cursor:pointer; border-bottom:1px solid var(--mc-border);">
                            <div class="fw-semibold" style="font-size:.85rem;">${d.titel.replace(/</g,'&lt;')}</div>
                            <div class="small text-muted">${(d.kapitel || '').replace(/</g,'&lt;')}</div>
                        </div>`).join('') || '<div class="small text-muted" style="padding:.6rem .75rem;">Alle Treffer sind bereits verlinkt.</div>';
                dropdown.style.display = 'block';
                dropdown.querySelectorAll('.verlinkung-vorschlag').forEach(el => {
                    el.addEventListener('click', () => {
                        const id = parseInt(el.getAttribute('data-id'));
                        const titel = el.getAttribute('data-titel');
                        verlinkungen.set(id, titel);
                        sucheInput.value = '';
                        dropdown.style.display = 'none';
                        renderChips();
                    });
                    el.addEventListener('mouseenter', () => el.style.background = 'var(--mc-bg)');
                    el.addEventListener('mouseleave', () => el.style.background = 'transparent');
                });
            }, 220);
        });
        document.addEventListener('click', e => {
            if (!e.target.closest('#verlinkungSuche') && !e.target.closest('#verlinkungDropdown'))
                dropdown.style.display = 'none';
        });
    })();
</script>
