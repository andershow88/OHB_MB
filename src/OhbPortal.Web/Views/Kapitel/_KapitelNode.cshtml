@model OhbPortal.Application.DTOs.KapitelBaumDto
@{
    bool istEditor = User.IsInRole("Editor") || User.IsInRole("Admin") || User.IsInRole("Bereichsverantwortlicher");
    bool istAdmin = User.IsInRole("Admin");
    var beschrEnc = System.Web.HttpUtility.JavaScriptStringEncode(Model.Beschreibung ?? string.Empty);
    var titelEnc = System.Web.HttpUtility.JavaScriptStringEncode(Model.Titel);
    var iconEnc = System.Web.HttpUtility.JavaScriptStringEncode(Model.Icon ?? string.Empty);
}
<li style="padding:.4rem 0; border-bottom:1px solid var(--mc-border);">
    <div class="d-flex align-items-center gap-2" style="margin-left:@(Model.Tiefe * 24)px;">
        <i class="bi @(Model.Icon ?? "bi-folder2")" style="color:var(--mc-gold); font-size:1rem;"></i>
        <a asp-controller="Dokumente" asp-action="Index" asp-route-kapitelId="@Model.Id"
           class="fw-semibold text-decoration-none" style="color:var(--mc-text);">
            @Model.Titel
        </a>
        @if (Model.DokumentenAnzahl > 0)
        {
            <span class="mc-badge badge-secondary">@Model.DokumentenAnzahl</span>
        }
        <div class="ms-auto d-flex gap-1 align-items-center">
            @if (istEditor)
            {
                <form asp-action="NachOben" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .4rem;" title="Nach oben">
                        <i class="bi bi-arrow-up"></i>
                    </button>
                </form>
                <form asp-action="NachUnten" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .4rem;" title="Nach unten">
                        <i class="bi bi-arrow-down"></i>
                    </button>
                </form>
                <button class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .4rem;" title="Bearbeiten"
                        data-bs-toggle="modal" data-bs-target="#kapitelBearbeitenModal"
                        onclick="kapitelVorbereiten(@Model.Id, '@Html.Raw(titelEnc)', '@Html.Raw(iconEnc)', '@Html.Raw(beschrEnc)')">
                    <i class="bi bi-pencil"></i>
                </button>
                <button class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .5rem;"
                        data-bs-toggle="modal" data-bs-target="#kapitelModal"
                        onclick="setElternId(@Model.Id)" title="Unterkapitel anlegen">
                    <i class="bi bi-plus"></i>
                </button>
            }
            <a asp-controller="Dokumente" asp-action="Neu" asp-route-kapitelId="@Model.Id"
               class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .5rem;" title="Dokument anlegen">
                <i class="bi bi-file-earmark-plus"></i>
            </a>
            @if (istAdmin)
            {
                <form asp-action="Loeschen" asp-route-id="@Model.Id" method="post" style="display:inline;"
                      onsubmit="return confirm('Kapitel wirklich löschen? Nur möglich wenn keine Unterkapitel oder Dokumente existieren.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-mc-ghost" style="font-size:.72rem; padding:.15rem .4rem; color:var(--mc-danger);" title="Löschen">
                        <i class="bi bi-trash"></i>
                    </button>
                </form>
            }
        </div>
    </div>
    @if (Model.Unterkapitel.Any())
    {
        <ul class="list-unstyled mb-0 mt-1">
            @foreach (var u in Model.Unterkapitel)
            {
                <partial name="_KapitelNode" model="u" />
            }
        </ul>
    }
</li>
