@model IEnumerable<OhbPortal.Application.DTOs.KapitelBaumDto>
@{
    ViewData["Title"] = "Themenbaum";
    bool istEditor = User.IsInRole("Editor") || User.IsInRole("Admin") || User.IsInRole("Bereichsverantwortlicher");
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-diagram-3 me-2"></i>Themenbaum</h1>
        <p class="mc-page-subtitle">Kapitel und Unterkapitel als Baumstruktur</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <button class="btn-mc-outline" onclick="alleKapitelAufklappen()" title="Nur Kapitel-Struktur aufklappen, Dokumente ausblenden" style="font-size:.8rem; padding:.3rem .75rem;">
            <i class="bi bi-folder2-open"></i> Kapitel aufklappen
        </button>
        <button class="btn-mc-outline" onclick="alleAufklappen()" title="Alles aufklappen — Kapitel und Dokumente (Alt+Shift+E)" style="font-size:.8rem; padding:.3rem .75rem;">
            <i class="bi bi-arrows-expand"></i> Alles aufklappen
        </button>
        <button class="btn-mc-outline" onclick="alleZuklappen()" title="Alles zuklappen (Alt+Shift+W)" style="font-size:.8rem; padding:.3rem .75rem;">
            <i class="bi bi-arrows-collapse"></i> Zuklappen
        </button>
        @if (istEditor)
        {
            <button class="btn-mc-primary" data-bs-toggle="modal" data-bs-target="#kapitelModal" onclick="setElternId(null)">
                <i class="bi bi-plus-circle"></i> Neues Hauptkapitel
            </button>
        }
    </div>
</div>

<div class="mc-card">
    <div class="mc-card-body">
        @if (!Model.Any())
        {
            <p class="text-muted">Keine Kapitel vorhanden.</p>
        }
        else
        {
            <ul class="list-unstyled mb-0 tree-root" id="kapitelBaum">
                <partial name="_KapitelTreeRoot" model="Model" />
            </ul>
        }
    </div>
</div>

<style>
    .tree-root { }
    .tree-node { position: relative; }
    .tree-row { transition: background .15s; }
    .tree-row:hover { background: rgba(0,81,90,.04); }
    .tree-toggle {
        background: none; border: none; cursor: pointer; padding: 0;
        width: 20px; height: 20px; display: inline-flex; align-items: center; justify-content: center;
        color: var(--mc-primary); font-size: .7rem; border-radius: 4px; transition: all .2s;
    }
    .tree-toggle:hover { background: rgba(0,81,90,.1); }
    .tree-chevron { transition: transform .25s ease; }
    .tree-chevron.open { transform: rotate(90deg); }
    .tree-children { overflow: hidden; transition: max-height .3s ease, opacity .25s ease; }
    .tree-children.collapsed { max-height: 0 !important; opacity: 0; }
    .tree-children.expanded { opacity: 1; }
    .tree-label:hover { color: var(--mc-primary) !important; }
    .tree-actions { opacity: .3; transition: opacity .2s; }
    .tree-row:hover .tree-actions { opacity: 1; }
    .tree-node::before {
        content: ''; position: absolute; left: 0; top: 0; bottom: 0;
        width: 1px; background: var(--mc-border); margin-left: calc(var(--mc-depth, 0) * 28px + 13px);
        display: none;
    }
    .tree-node:not(:last-child)::before { display: block; }

    /* Drag-and-Drop */
    .tree-grip {
        cursor: grab; color: var(--mc-text-muted); font-size: 1rem; padding: 0 .15rem;
        opacity: .35; transition: opacity .15s, color .15s;
        user-select: none;
    }
    .tree-grip-visible { opacity: .55; }
    .tree-row:hover .tree-grip { opacity: 1; }
    .tree-grip:hover { color: var(--mc-primary); }
    .tree-grip:active { cursor: grabbing; }
    .tree-doc-row[draggable="true"] { cursor: grab; }
    .tree-doc-row[draggable="true"]:active { cursor: grabbing; }
    .tree-row.dnd-dragging { opacity: .45; }

    /* Strukturansicht — Dokumente ausblenden */
    .tree-root.hide-docs .tree-doc-node { display: none !important; }
    .tree-row.dnd-target-above { box-shadow: inset 0 2px 0 var(--mc-primary); }
    .tree-row.dnd-target-below { box-shadow: inset 0 -2px 0 var(--mc-primary); }
    .tree-row.dnd-target-inside {
        background: rgba(0,81,90,.12) !important;
        outline: 2px dashed var(--mc-primary);
        outline-offset: -2px;
    }
</style>

@if (istEditor)
{
    <!-- Schnell-Anlegen-Modal Dokument -->
    <div class="modal fade" id="dokumentSchnellModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-plus me-2"></i>Dokument anlegen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="dokumentSchnellKapitelInfo" class="mb-3" style="padding:.5rem .75rem; background:rgba(0,81,90,.05); border-radius:var(--mc-radius-sm); font-size:.85rem;">
                        <i class="bi bi-arrow-return-right" style="color:var(--mc-primary);"></i>
                        Im Kapitel: <strong id="dokumentSchnellKapitelName"></strong>
                    </div>
                    <input type="hidden" id="dokumentSchnellKapitelId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Titel</label>
                        <input type="text" id="dokumentSchnellTitel" class="form-control" required autocomplete="off" placeholder="Aussagekräftiger Titel" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kategorie (optional)</label>
                        <input type="text" id="dokumentSchnellKategorie" class="form-control" list="dokumentSchnellKategorieListe" placeholder="z.B. Richtlinie, Verfahrensanweisung" />
                        <datalist id="dokumentSchnellKategorieListe">
                            <option>Richtlinie</option>
                            <option>Verfahrensanweisung</option>
                            <option>Geschäftsanweisung</option>
                            <option>Leitlinie</option>
                            <option>Strategie</option>
                            <option>Handbuch</option>
                            <option>Formular</option>
                            <option>Verzeichnis</option>
                            <option>Anlage</option>
                        </datalist>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold">Kurzbeschreibung (optional)</label>
                        <input type="text" id="dokumentSchnellKurz" class="form-control" placeholder="Einzeiler – erscheint in Listen" />
                    </div>
                    <div class="small text-muted mt-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Nach dem Anlegen wirst du direkt zum Editor weitergeleitet.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="button" id="dokumentSchnellSubmit" class="btn-mc-primary">
                        <i class="bi bi-arrow-right-circle me-1"></i>Anlegen & Bearbeiten
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="kapitelModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Anlegen" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="kapitelElternId" name="elternId" value="" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-diagram-3 me-2"></i>Kapitel anlegen</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div id="kapitelElternInfo" style="display:none; margin-bottom:.75rem; padding:.5rem .75rem; background:rgba(0,81,90,.05); border-radius:var(--mc-radius-sm); font-size:.85rem;">
                            <i class="bi bi-arrow-return-right" style="color:var(--mc-primary);"></i>
                            Unterkapitel von: <strong id="kapitelElternName"></strong>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Titel</label>
                            <input name="titel" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Bootstrap-Icon (optional)</label>
                            <input name="icon" class="form-control" placeholder="bi-folder2-open" />
                            <div class="small text-muted">siehe icons.getbootstrap.com</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Beschreibung (optional)</label>
                            <textarea name="beschreibung" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn-mc-primary"><i class="bi bi-check2 me-1"></i>Anlegen</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="kapitelBearbeitenModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Bearbeiten" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="kb_id" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Kapitel bearbeiten</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Titel</label>
                            <input name="titel" id="kb_titel" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Bootstrap-Icon</label>
                            <input name="icon" id="kb_icon" class="form-control" placeholder="bi-folder2-open" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Beschreibung (optional)</label>
                            <textarea name="beschreibung" id="kb_beschreibung" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn-mc-primary"><i class="bi bi-check2 me-1"></i>Speichern</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    function setElternId(id) {
        document.getElementById('kapitelElternId').value = id ?? '';
        var info = document.getElementById('kapitelElternInfo');
        if (id && info) {
            var node = document.querySelector('[data-kapitel-id="' + id + '"] .tree-label');
            document.getElementById('kapitelElternName').textContent = node ? node.textContent.trim() : '#' + id;
            info.style.display = 'block';
        } else if (info) {
            info.style.display = 'none';
        }
    }

    // ── Schnell-Anlegen Dokument ──
    function dokumentSchnellOeffnen(kapitelId, kapitelName) {
        document.getElementById('dokumentSchnellKapitelId').value = kapitelId;
        document.getElementById('dokumentSchnellKapitelName').textContent = kapitelName || ('#' + kapitelId);
        document.getElementById('dokumentSchnellTitel').value = '';
        document.getElementById('dokumentSchnellKategorie').value = '';
        document.getElementById('dokumentSchnellKurz').value = '';
        setTimeout(function () {
            document.getElementById('dokumentSchnellTitel').focus();
        }, 200);
    }

    (function () {
        var btn = document.getElementById('dokumentSchnellSubmit');
        if (!btn) return;
        async function submit() {
            var titel = document.getElementById('dokumentSchnellTitel').value.trim();
            var kapitelId = document.getElementById('dokumentSchnellKapitelId').value;
            var kategorie = document.getElementById('dokumentSchnellKategorie').value.trim();
            var kurz = document.getElementById('dokumentSchnellKurz').value.trim();
            if (!titel) {
                if (window.mcToast) mcToast('Bitte einen Titel eingeben.', 'danger');
                document.getElementById('dokumentSchnellTitel').focus();
                return;
            }
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Lege an …';
            try {
                var fd = new FormData();
                fd.append('titel', titel);
                fd.append('kapitelId', kapitelId);
                if (kategorie) fd.append('kategorie', kategorie);
                if (kurz) fd.append('kurzbeschreibung', kurz);
                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) fd.append('__RequestVerificationToken', token);
                var resp = await fetch('/Dokumente/SchnellAnlegen', { method: 'POST', body: fd, credentials: 'same-origin' });
                if (!resp.ok) {
                    var msg = await resp.text();
                    throw new Error(msg || resp.statusText);
                }
                var data = await resp.json();
                if (data && data.redirect) {
                    window.location.href = data.redirect;
                } else if (data && data.id) {
                    window.location.href = '/Dokumente/Bearbeiten/' + data.id;
                }
            } catch (ex) {
                if (window.mcToast) mcToast('Anlegen fehlgeschlagen: ' + (ex.message || ex), 'danger');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-arrow-right-circle me-1"></i>Anlegen & Bearbeiten';
            }
        }
        btn.addEventListener('click', submit);
        document.getElementById('dokumentSchnellTitel').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); submit(); }
        });
        document.getElementById('dokumentSchnellKategorie').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); submit(); }
        });
    })();

    function kapitelVorbereiten(id, titel, icon, beschreibung) {
        document.getElementById('kb_id').value = id;
        document.getElementById('kb_titel').value = titel || '';
        document.getElementById('kb_icon').value = icon || '';
        document.getElementById('kb_beschreibung').value = beschreibung || '';
    }

    // ── Persistent Expand-State (überlebt Reload + Navigation) ──
    // v2: alte Keys werden ignoriert (Reset wegen geänderter Logik)
    var EXPAND_KEY = 'ohb-tree-expanded-v2';
    try { localStorage.removeItem('ohb-tree-expanded'); } catch (_) {}
    function loadExpandedSet() {
        try { return new Set(JSON.parse(localStorage.getItem(EXPAND_KEY) || '[]')); }
        catch (_) { return new Set(); }
    }
    function saveExpandedSet(set) {
        try { localStorage.setItem(EXPAND_KEY, JSON.stringify(Array.from(set))); } catch (_) {}
    }
    function applyExpandedState() {
        var set = loadExpandedSet();
        set.forEach(function (id) {
            var el = document.getElementById('kap-' + id);
            if (!el) return;
            el.style.display = '';
            el.classList.remove('collapsed');
            el.classList.add('expanded');
            el.style.maxHeight = 'none';
            var chev = document.getElementById('chevron-kap-' + id);
            if (chev) chev.classList.add('open');
        });
    }

    // ── Tree Toggle ──
    function toggleKapitel(nodeId) {
        var el = document.getElementById(nodeId);
        var chev = document.getElementById('chevron-' + nodeId);
        if (!el) return;
        var idMatch = nodeId.match(/^kap-(\d+)/);
        var id = idMatch ? parseInt(idMatch[1]) : null;
        var set = loadExpandedSet();

        var isHidden = el.style.display === 'none' || el.classList.contains('collapsed');
        if (isHidden) {
            el.style.display = '';
            el.classList.remove('collapsed');
            el.classList.add('expanded');
            el.style.maxHeight = el.scrollHeight + 'px';
            if (chev) chev.classList.add('open');
            setTimeout(function () { el.style.maxHeight = 'none'; }, 300);
            if (id !== null) set.add(id);
        } else {
            el.style.maxHeight = el.scrollHeight + 'px';
            requestAnimationFrame(function () {
                el.classList.add('collapsed');
                el.classList.remove('expanded');
                el.style.maxHeight = '0';
            });
            if (chev) chev.classList.remove('open');
            setTimeout(function () { el.style.display = 'none'; el.style.maxHeight = ''; }, 300);
            if (id !== null) set.delete(id);
        }
        saveExpandedSet(set);
    }

    function alleAufklappen() {
        var set = loadExpandedSet();
        document.querySelectorAll('.tree-children').forEach(function (el) {
            el.style.display = '';
            el.classList.remove('collapsed');
            el.classList.add('expanded');
            el.style.maxHeight = 'none';
            var m = el.id && el.id.match(/^kap-(\d+)/);
            if (m) set.add(parseInt(m[1]));
        });
        document.querySelectorAll('.tree-chevron').forEach(function (c) { c.classList.add('open'); });
        saveExpandedSet(set);
    }

    function alleZuklappen() {
        document.querySelectorAll('.tree-children').forEach(function (el) {
            el.style.display = 'none';
            el.classList.add('collapsed');
            el.classList.remove('expanded');
            el.style.maxHeight = '';
        });
        document.querySelectorAll('.tree-chevron').forEach(function (c) { c.classList.remove('open'); });
        saveExpandedSet(new Set());
        var root = document.getElementById('kapitelBaum');
        if (root) root.classList.remove('hide-docs');
    }

    function alleKapitelAufklappen() {
        var root = document.getElementById('kapitelBaum');
        if (root) root.classList.add('hide-docs');
        alleAufklappen();
    }

    // Beim ersten Laden den gespeicherten Zustand wiederherstellen
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applyExpandedState);
    } else {
        applyExpandedState();
    }

    // ── Soft-Reload: Tree per AJAX austauschen statt Page-Reload ──
    async function reloadTree() {
        try {
            var resp = await fetch('/Kapitel/TreePartial', { credentials: 'same-origin' });
            if (!resp.ok) throw new Error('Tree konnte nicht geladen werden (' + resp.status + ')');
            var html = await resp.text();
            var root = document.getElementById('kapitelBaum');
            if (!root) return;
            root.innerHTML = html;
            applyExpandedState();
            if (window.initTreeDnD) window.initTreeDnD();
        } catch (ex) {
            if (window.mcToast) mcToast('Aktualisierung fehlgeschlagen — Seite wird neu geladen.', 'danger');
            setTimeout(function () { location.reload(); }, 1200);
        }
    }
    window.reloadTree = reloadTree;

    // ── Keyboard Shortcuts ──
    document.addEventListener('keydown', function (e) {
        if (e.altKey && e.shiftKey && !e.ctrlKey && !e.metaKey) {
            if (e.key === 'E' || e.key === 'e') { e.preventDefault(); alleAufklappen(); }
            if (e.key === 'W' || e.key === 'w') { e.preventDefault(); alleZuklappen(); }
        }
    });

    // ── Drag-and-Drop (nur Editoren) — Event-Delegation, kein Re-Binding nach Soft-Reload ──
    @if (istEditor)
    {
        <text>
        (function () {
            var dragState = null;  // { type, id, kapitelIdOfDoc?, row }

            function clearTargets() {
                document.querySelectorAll('.tree-row').forEach(function (r) {
                    r.classList.remove('dnd-target-above', 'dnd-target-below', 'dnd-target-inside');
                });
            }
            function getToken() {
                var el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : null;
            }

            // Hilfsfunktion: aus einer Row bestimmen, ob sie Doc oder Chapter ist
            function rowContext(row) {
                if (!row) return null;
                var isDoc = row.classList.contains('tree-doc-row');
                if (isDoc) {
                    var docLi = row.closest('[data-dokument-id]');
                    return docLi ? {
                        kind: 'doc',
                        docLi: docLi,
                        docId: parseInt(docLi.getAttribute('data-dokument-id')),
                        kapitelIdOfDoc: parseInt(docLi.getAttribute('data-kapitel-id-of-doc') || '0')
                    } : null;
                } else {
                    var kapLi = row.closest('[data-kapitel-id]');
                    return kapLi ? {
                        kind: 'kapitel',
                        kapLi: kapLi,
                        kapitelId: parseInt(kapLi.getAttribute('data-kapitel-id'))
                    } : null;
                }
            }

            // ── DRAGSTART (Delegation) ──
            document.addEventListener('dragstart', function (e) {
                var target = e.target;
                if (!target || !target.closest) return;

                // Kandidaten: tree-doc-row mit draggable=true, oder tree-grip auf Chapter
                var docRow = target.closest('.tree-doc-row');
                var grip = target.closest('.tree-grip');

                // Doc-Drag erkennen
                if (docRow && docRow.getAttribute('draggable') === 'true') {
                    var docLi = docRow.closest('[data-dokument-id]');
                    if (!docLi) return;
                    dragState = {
                        type: 'dokument',
                        id: parseInt(docLi.getAttribute('data-dokument-id')),
                        kapitelIdOfDoc: parseInt(docLi.getAttribute('data-kapitel-id-of-doc') || '0'),
                        row: docRow
                    };
                }
                // Chapter-Drag erkennen (Grip auf einer Chapter-Zeile, NICHT in einem Doc)
                else if (grip && grip.getAttribute('draggable') === 'true' && !grip.closest('[data-dokument-id]')) {
                    var kapLi = grip.closest('[data-kapitel-id]');
                    if (!kapLi) return;
                    dragState = {
                        type: 'kapitel',
                        id: parseInt(kapLi.getAttribute('data-kapitel-id')),
                        row: kapLi.querySelector(':scope > .tree-row')
                    };
                }
                else {
                    // Nicht für uns relevant
                    return;
                }

                if (dragState.row) dragState.row.classList.add('dnd-dragging');
                e.dataTransfer.effectAllowed = 'move';
                try { e.dataTransfer.setData('text/plain', String(dragState.id)); } catch (_) {}
                if (e.dataTransfer.setDragImage && dragState.row) {
                    e.dataTransfer.setDragImage(dragState.row, 10, 10);
                }
            });

            // ── DRAGEND (Delegation) ──
            document.addEventListener('dragend', function () {
                if (dragState && dragState.row) dragState.row.classList.remove('dnd-dragging');
                clearTargets();
                dragState = null;
            });

            // ── DRAGOVER (Delegation) ──
            document.addEventListener('dragover', function (e) {
                if (!dragState) return;
                var row = e.target && e.target.closest ? e.target.closest('.tree-row') : null;
                if (!row) return;
                var ctx = rowContext(row);
                if (!ctx) return;

                // Self-drop ignorieren
                if (dragState.type === 'kapitel' && ctx.kind === 'kapitel' && ctx.kapitelId === dragState.id) return;
                if (dragState.type === 'dokument' && ctx.kind === 'doc' && ctx.docId === dragState.id) return;

                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';

                clearTargets();

                if (dragState.type === 'dokument') {
                    row.classList.add('dnd-target-inside');
                } else {
                    var rect = row.getBoundingClientRect();
                    var y = e.clientY - rect.top;
                    var h = rect.height;
                    if (y < h * 0.28) row.classList.add('dnd-target-above');
                    else if (y > h * 0.72) row.classList.add('dnd-target-below');
                    else row.classList.add('dnd-target-inside');
                }
            });

            // ── DROP (Delegation) ──
            document.addEventListener('drop', function (e) {
                if (!dragState) return;
                var row = e.target && e.target.closest ? e.target.closest('.tree-row') : null;
                if (!row) return;
                var ctx = rowContext(row);
                if (!ctx) return;

                e.preventDefault();
                e.stopPropagation();

                // Self-drop
                if (dragState.type === 'kapitel' && ctx.kind === 'kapitel' && ctx.kapitelId === dragState.id) {
                    clearTargets(); return;
                }
                if (dragState.type === 'dokument' && ctx.kind === 'doc' && ctx.docId === dragState.id) {
                    clearTargets(); return;
                }

                var token = getToken();
                if (!token) { if (window.mcToast) mcToast('Antiforgery-Token fehlt', 'danger'); return; }

                var url, fd = new FormData();
                fd.append('__RequestVerificationToken', token);

                if (dragState.type === 'kapitel') {
                    // Chapter-Verschieben — Ziel muss Chapter sein
                    if (ctx.kind !== 'kapitel') {
                        // Drop auf Doc-Row — verwende dessen Parent-Kapitel
                        var parentKap = row.closest('[data-kapitel-id]');
                        if (!parentKap) { clearTargets(); return; }
                        ctx = { kind: 'kapitel', kapitelLi: parentKap, kapitelId: parseInt(parentKap.getAttribute('data-kapitel-id')) };
                    }
                    var position = row.classList.contains('dnd-target-above') ? 'before'
                                  : row.classList.contains('dnd-target-below') ? 'after'
                                  : 'inside';
                    url = '/Kapitel/Verschieben';
                    fd.append('id', String(dragState.id));
                    fd.append('zielId', String(ctx.kapitelId));
                    fd.append('position', position);
                } else {
                    // Doc-Verschieben — Ziel-Kapitel ermitteln
                    var zielKapitelId;
                    if (ctx.kind === 'kapitel') {
                        zielKapitelId = ctx.kapitelId;
                    } else {
                        // Drop auf einer Doc-Zeile -> Doc landet im Kapitel dieses Dokuments
                        zielKapitelId = ctx.kapitelIdOfDoc;
                    }
                    if (!zielKapitelId || zielKapitelId === dragState.kapitelIdOfDoc) {
                        clearTargets(); dragState = null; return;
                    }
                    url = '/Dokumente/Verschieben';
                    fd.append('id', String(dragState.id));
                    fd.append('zielKapitelId', String(zielKapitelId));
                }

                clearTargets();

                fetch(url, { method: 'POST', body: fd, credentials: 'same-origin' })
                    .then(function (res) {
                        if (res.ok) {
                            if (window.mcToast) mcToast('Verschoben ✓', 'success', { duration: 1800 });
                            return reloadTree();
                        }
                        return res.text().then(function (t) { throw new Error(t || res.statusText); });
                    })
                    .catch(function (err) {
                        if (window.mcToast) mcToast('Verschieben fehlgeschlagen: ' + (err.message || err), 'danger');
                    });
            });

            // Soft-Reload braucht kein Re-Binding mehr (Delegation)
            window.initTreeDnD = function () { /* delegated, no-op */ };
        })();
        </text>
    }
</script>
}
